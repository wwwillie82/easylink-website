---
import '../styles/global.css';
import CookieConsent from '@/components/CookieConsent.astro';
import Ga4Analytics from '@/components/Ga4Analytics.astro';
import { getPublicSiteSettings } from '@/lib/content/settings';
const publicSettings = await getPublicSiteSettings();
const { title = 'Easylink — Cégvezetés, könnyedén.', description = 'Modern ügyviteli rendszer számlázáshoz, adminisztrációhoz, CRM-hez és AI támogatott döntésekhez.' } = Astro.props;
---
<!doctype html>
<html lang="hu">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex,nofollow" />
    <link rel="icon" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <CookieConsent consent={publicSettings.consent} />
    <Ga4Analytics analytics={publicSettings.analytics} />
  </body>
</html>
