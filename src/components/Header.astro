---
import { deployUrl } from '@/content/siteNavigation';
import { listNavigation } from '@/lib/content/provider';

const siteNavigation = await listNavigation();
---
<header class="site-header">
  <div class="container nav-wrap">
    <a
      class="brand"
      href="/"
      aria-label="Easylink főoldal"
    >
      <span class="brand-logo-frame">
        <img
          src="/assets/brand/easylink-logo-horizontal.png"
          alt="Easylink"
        />
      </span>
    </a>

    <nav aria-label="Fő navigáció">
      {
        siteNavigation.map((item) => (
          <a href={item.href}>
            {item.title}
          </a>
        ))
      }
    </nav>

    <a
      class="button button-primary nav-cta"
      href={deployUrl}
    >
      Demót kérek
    </a>
  </div>
</header>
<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(15, 17, 89, 0.08);
    box-shadow: 0 18px 50px rgba(15, 17, 89, 0.06);
  }

  .nav-wrap {
    min-height: var(--header-height);
    display: grid;
    grid-template-columns: minmax(168px, auto) minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(10px, 1.5vw, 18px);
  }

  .brand,
  .brand-logo-frame {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    overflow: visible;
  }

  .brand-logo-frame {
    width: min(33vw, var(--logo-max-width));
    min-width: 150px;
    height: var(--logo-max-height);
  }

  .brand img {
    display: block;
    width: auto;
    max-width: 100%;
    height: auto;
    max-height: var(--logo-max-height);
    object-fit: contain;
    object-position: left center;
  }

  nav {
    display: flex;
    gap: 8px;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    min-width: 0;
    font-size: 0.86rem;
    color: var(--color-navy);
    font-weight: 700;
  }

  nav a {
    padding: 8px 10px;
    border-radius: var(--radius-pill);
    opacity: 0.78;
    white-space: nowrap;
  }

  nav a:hover,
  nav a:focus-visible {
    opacity: 1;
    background: #f1f5f0;
    outline: none;
  }

  .nav-cta {
    padding: 11px 17px;
    white-space: nowrap;
  }

  @media (max-width: 980px) {
    .nav-wrap {
      min-height: var(--header-height-mobile);
      padding-top: 9px;
      padding-bottom: 9px;
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .brand-logo-frame {
      width: var(--logo-max-width-mobile);
      min-width: 138px;
      height: var(--logo-max-height-mobile);
    }

    .brand img { max-height: var(--logo-max-height-mobile); }

    nav {
      grid-column: 1 / -1;
      justify-content: flex-start;
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 2px;
      scrollbar-width: none;
    }

    nav::-webkit-scrollbar { display: none; }
  }

  @media (max-width: 560px) {
    .nav-wrap { grid-template-columns: 1fr; }
    .nav-cta { width: 100%; }
    nav { font-size: 0.82rem; }
  }
</style>
