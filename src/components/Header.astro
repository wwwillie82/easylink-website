---
import { siteNavigation, deployUrl } from '@/content/siteNavigation';
---
<header class="site-header">
  <div class="container nav-wrap">
    <a class="brand" href="/" aria-label="Easylink főoldal">
      <img src="/assets/brand/easylink-logo-horizontal.png" alt="Easylink" />
    </a>
    <nav aria-label="Fő navigáció">{siteNavigation.map((item) => <a href={item.href}>{item.title}</a>)}</nav>
    <a class="button button-primary nav-cta" href={deployUrl}>Demót kérek</a>
  </div>
</header>
<style>
  .site-header{position:sticky;top:0;z-index:20;background:rgba(255,255,255,.92);backdrop-filter:blur(18px);border-bottom:1px solid rgba(15,17,89,.08);box-shadow:0 18px 50px rgba(15,17,89,.06)}
  .nav-wrap{min-height:78px;display:flex;align-items:center;justify-content:space-between;gap:24px}
  .brand{display:inline-flex;align-items:center;flex:0 0 auto}.brand img{display:block;width:clamp(150px,17vw,210px);height:auto}
  nav{display:flex;gap:8px;align-items:center;justify-content:center;flex-wrap:wrap;font-size:.9rem;color:var(--color-navy);font-weight:700}
  nav a{padding:10px 12px;border-radius:999px;opacity:.78}nav a:hover,nav a:focus-visible{opacity:1;background:#f1f5f0;outline:none}
  .nav-cta{padding:13px 19px;white-space:nowrap}
  @media(max-width:980px){.nav-wrap{min-height:auto;padding-top:14px;padding-bottom:14px;display:grid;grid-template-columns:1fr auto}.brand img{width:156px}nav{grid-column:1/-1;justify-content:flex-start;overflow:auto;flex-wrap:nowrap;padding-bottom:2px}.nav-cta{grid-column:2;grid-row:1}}
  @media(max-width:560px){.nav-wrap{grid-template-columns:1fr}.nav-cta{grid-column:1;grid-row:auto;width:100%}nav{font-size:.82rem}}
</style>
