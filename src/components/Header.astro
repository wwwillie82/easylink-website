---
import { listNavigation } from '@/lib/content/provider';
import { getPublicSiteSettings } from '@/lib/content/settings';
import { resolvePageHeaderCta } from '@/lib/content/pageCta';

const { pageCtaBlock = null } = Astro.props;
const siteNavigation = await listNavigation();
const publicSettings = await getPublicSiteSettings();
const brand = publicSettings.brand;
const headerCta = resolvePageHeaderCta(pageCtaBlock, publicSettings.defaultCta);
const validIntent = (value) => ['demo','trial','email'].includes(String(value || '')) ? String(value) : '';
const safeId = (value, fallback) => String(value || fallback).trim().replace(/[^a-zA-Z0-9_.:-]/g, '-').slice(0, 80);
---
<header class="site-header">
  <div class="container nav-wrap">
    <a class="brand" href="/" aria-label="Easylink főoldal">
      <span class="brand-logo-frame">
        <img src={brand.headerLogoPath} alt={brand.headerLogoAlt} />
      </span>
    </a>

    <nav aria-label="Fő navigáció">
      {siteNavigation.map((item) => <a href={item.href}>{item.title}</a>)}
    </nav>

    {headerCta.shouldRender && (
      <div class="nav-ctas" aria-label="Kiemelt műveletek">
        {headerCta.buttons.map((button, index) => {
          const intent = validIntent(button.analyticsIntent ?? (index === 0 ? 'demo' : index === 1 ? 'trial' : ''));
          const id = safeId(button.analyticsId, `site-header-${index + 1}`);
          return (
            <a
              class={`button ${index === 0 ? 'button-primary' : 'button-secondary'} nav-cta`}
              href={button.url}
              data-easylink-cta={intent || undefined}
              data-easylink-cta-id={intent ? id : undefined}
              data-easylink-cta-slot={intent ? (button.analyticsSlot || 'header') : undefined}
            >
              {button.label}
            </a>
          );
        })}
      </div>
    )}
  </div>
</header>
<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(15, 17, 89, 0.08);
    box-shadow: 0 18px 50px rgba(15, 17, 89, 0.06);
  }

  .nav-wrap {
    min-height: var(--header-height);
    display: grid;
    grid-template-columns: minmax(168px, auto) minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(10px, 1.5vw, 18px);
  }

  .brand,
  .brand-logo-frame {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    overflow: visible;
  }

  .brand-logo-frame {
    width: min(33vw, var(--logo-max-width));
    min-width: 150px;
    height: var(--logo-max-height);
  }

  .brand img {
    display: block;
    width: auto;
    max-width: 100%;
    height: auto;
    max-height: var(--logo-max-height);
    object-fit: contain;
    object-position: left center;
  }

  nav {
    display: flex;
    gap: 8px;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    min-width: 0;
    font-size: 0.86rem;
    color: var(--color-navy);
    font-weight: 700;
  }

  nav a {
    padding: 8px 10px;
    border-radius: var(--radius-pill);
    opacity: 0.78;
    white-space: nowrap;
  }

  nav a:hover,
  nav a:focus-visible {
    opacity: 1;
    background: #f1f5f0;
    outline: none;
  }

  .nav-ctas {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 8px;
    flex-wrap: wrap;
    max-width: min(44vw, 620px);
  }

  .nav-cta {
    padding: 10px 14px;
    white-space: nowrap;
  }

  @media (max-width: 1180px) {
    .nav-wrap { grid-template-columns: minmax(150px, auto) minmax(0, 1fr); }
    .nav-ctas { grid-column: 1 / -1; max-width: none; justify-content: flex-end; padding-bottom: 10px; }
  }

  @media (max-width: 980px) {
    .nav-wrap {
      min-height: var(--header-height-mobile);
      padding-top: 9px;
      padding-bottom: 9px;
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .brand-logo-frame {
      width: var(--logo-max-width-mobile);
      min-width: 138px;
      height: var(--logo-max-height-mobile);
    }

    .brand img { max-height: var(--logo-max-height-mobile); }

    nav {
      grid-column: 1 / -1;
      justify-content: flex-start;
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 2px;
      scrollbar-width: none;
    }

    nav::-webkit-scrollbar { display: none; }
    .nav-ctas { justify-content: flex-start; }
  }

  @media (max-width: 560px) {
    .nav-wrap { grid-template-columns: 1fr; }
    .nav-ctas { display: grid; grid-template-columns: 1fr; width: 100%; }
    .nav-cta { width: 100%; }
    nav { font-size: 0.82rem; }
  }
</style>
