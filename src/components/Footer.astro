---
import { getPublicSiteSettings } from '@/lib/content/settings';
const publicSettings = await getPublicSiteSettings();
const legalDocuments = publicSettings.legalDocuments;
const contact = publicSettings.contact;
const emailHref = contact.email ? `mailto:${contact.email}` : '';
const phoneHref = contact.phone ? `tel:${contact.phone.replace(/[^+0-9]/g, '')}` : '';
const addressLines = [contact.companyName, [contact.postalCode, contact.city].filter(Boolean).join(' '), contact.addressLine, contact.country].filter(Boolean);
const legalLinks = (legalDocuments.items?.length ? legalDocuments.items.map((d) => [d.label, d.pdfPath]) : [
  ['Általános Szerződési Feltételek', legalDocuments.termsPdfPath],
  ['Adatkezelési Tájékoztató', legalDocuments.privacyPdfPath],
  ['Cookie Tájékoztató', legalDocuments.cookiePdfPath],
]).filter(([, href]) => Boolean(href));
const socialLinks = publicSettings.social || [];
const socialLabels = { facebook: 'Facebook', instagram: 'Instagram', tiktok: 'TikTok', youtube: 'YouTube', linkedin: 'LinkedIn' };
const socialIcon = (id) => ({ facebook: 'M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z', instagram: 'M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5zm5 5a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm6-.5a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3z', tiktok: 'M14 2c1 4 3 6 7 6v4c-2 0-4-.6-6-2v6a6 6 0 1 1-6-6h1v4H9a2 2 0 1 0 2 2V2z', youtube: 'M21 7.5a3 3 0 0 0-2-2C17 5 12 5 12 5s-5 0-7 .5a3 3 0 0 0-2 2A31 31 0 0 0 3 12a31 31 0 0 0 .5 4.5 3 3 0 0 0 2 2C7 19 12 19 12 19s5 0 7-.5a3 3 0 0 0 2-2A31 31 0 0 0 21 12a31 31 0 0 0 0-4.5zM10 15V9l5 3z', linkedin: 'M4 3a2 2 0 1 0 0 4 2 2 0 0 0 0-4zM3 8h3v13H3zm6 0h3v2c1-1.5 2.2-2.3 4-2.3 3 0 5 2 5 6V21h-3v-7c0-2-1-3-2.5-3S12 12 12 14v7H9z' }[id] || '');
const hasLegalNavigation = legalLinks.length > 0 || publicSettings.consent.active;
---
<footer id="kapcsolat" class="footer">
  <div class="container foot">
    <div class="footer-brand-column">
      <a class="brand" href="/">
        <img src={publicSettings.brand.footerLogoPath} alt={publicSettings.brand.footerLogoAlt} />
      </a>
      {socialLinks.length > 0 && <nav class="footer-social-navigation" aria-label="Közösségi oldalak">{socialLinks.map((item) => <a href={item.url} target="_blank" rel="noopener noreferrer me" aria-label={`${socialLabels[item.id] || item.id} oldal`}><svg viewBox="0 0 24 24" aria-hidden="true"><path d={socialIcon(item.id)} /></svg></a>)}</nav>}
      {hasLegalNavigation && <nav class="footer-legal-navigation" aria-label="Jogi dokumentumok és beállítások">
        {legalLinks.map(([label, href]) => <a href={href} target="_blank" rel="noopener noreferrer">{label}</a>)}
        {publicSettings.consent.active && <button type="button" class="cookie-settings-button" data-easylink-open-cookie-settings>Cookie-beállítások</button>}
      </nav>}
    </div>
    <div class="footer-contact-column" aria-label="Kapcsolati adatok">
      <b>Kapcsolat</b>
      {emailHref && <a href={emailHref} data-easylink-cta="email" data-easylink-cta-id="footer-email" data-easylink-cta-slot="footer">{contact.email}</a>}
      {phoneHref && <a href={phoneHref}>{contact.phone}</a>}
      {addressLines.length > 0 && <address>{addressLines.map((line) => <span>{line}</span>)}</address>}
    </div>
  </div>
</footer>

<style>
  .footer { padding: 56px 0; background: #f5f7f4; border-top: 1px solid var(--color-line); }
  .foot { display: grid; grid-template-columns: minmax(0, 1fr) minmax(280px, 420px); align-items: start; justify-content: space-between; gap: clamp(40px, 9vw, 128px); }
  .footer-brand-column, .footer-contact-column, .footer-legal-navigation { display: grid; align-content: start; }
  .footer-brand-column { gap: 24px; }
  .brand { width: fit-content; }
  .brand img { width: 180px; max-width: 100%; }
  .footer-legal-navigation { gap: 12px; max-width: 360px; }
  .footer-social-navigation { display: flex; gap: 12px; align-items: center; }
  .footer-social-navigation a { width: 36px; height: 36px; display: inline-grid; place-items: center; border: 1px solid rgba(15,17,89,.14); border-radius: 999px; }
  .footer-social-navigation svg { width: 19px; height: 19px; fill: currentColor; }
  .footer-contact-column { gap: 10px; max-width: 420px; justify-self: start; }
  address { display: grid; gap: 4px; font-style: normal; color: var(--color-ink); }
  .foot a:not(.brand), .cookie-settings-button { color: var(--color-navy); font-weight: 700; }
  .cookie-settings-button { appearance: none; border: 0; background: transparent; padding: 0; text-align: left; cursor: pointer; font: inherit; text-decoration: underline; width: fit-content; }
  .foot a:focus-visible, .cookie-settings-button:focus-visible { outline: 3px solid #ffbf47; outline-offset: 3px; border-radius: 4px; }
  @media (max-width: 700px) { .footer { padding: 44px 0; } .foot { grid-template-columns: 1fr; gap: 32px; } .footer-contact-column { max-width: 100%; } }
</style>
