---
import { getPublicLegalDocuments } from '@/lib/content/settings';
const legalDocuments = await getPublicLegalDocuments();
const legalLinks = [
  ['Általános Szerződési Feltételek', legalDocuments.termsPdfPath],
  ['Adatkezelési Tájékoztató', legalDocuments.privacyPdfPath],
  ['Cookie Tájékoztató', legalDocuments.cookiePdfPath],
].filter(([, href]) => Boolean(href));
---
<footer id="kapcsolat" class="footer">
  <div class="container foot">
    <div>
      <a class="brand" href="/">
        <img src="/assets/brand/easylink-logo-horizontal.png" alt="Easylink" />
      </a>
      <p>Statikus Astro marketing site staging környezethez.</p>
    </div>
    <div>
      <b>Kapcsolat</b>
      <a href="mailto:hello@easylink.hu">hello@easylink.hu</a>
      <a href={import.meta.env.PUBLIC_DEPLOY_URL ?? 'https://deploy.easylink.hu'}>Belépés / demo</a>
      {legalLinks.length > 0 && <div class="legal-links" aria-label="Jogi dokumentumok">{legalLinks.map(([label, href]) => <a href={href} target="_blank" rel="noopener noreferrer">{label}</a>)}</div>}
    </div>
  </div>
</footer>

<style>
  .footer { padding: 52px 0; background: #f5f7f4; border-top: 1px solid var(--color-line); }
  .foot { display: flex; justify-content: space-between; gap: 24px; }
  .brand img { width: 180px; }
  .foot div:last-child { display: grid; gap: 10px; }
  .legal-links { display: grid; gap: 8px; margin-top: 8px; }
  .foot a:not(.brand) { color: var(--color-navy); font-weight: 700; }
  @media (max-width: 700px) { .foot { display: grid; } }
</style>
