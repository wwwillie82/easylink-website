---
const { title = 'Kapcsolódó oldalak', body = '', links = [] } = Astro.props;
const lead = String(body || '').trim();
---
<section class="section related">
  <div class="container">
    <span class="eyebrow">Tovább</span>
    <h2>{title}</h2>
    {lead && <p class="related__body">{lead}</p>}
    <div class="links">
      {
        links.map((link) => (
          <a
            class="button button-secondary"
            href={link.href}
          >
            {link.title}
          </a>
        ))
      }
    </div>
  </div>
</section>
<style>
  .related {
    position: relative;
    overflow: hidden;
    background: #080a34;
    color: white;
  }

  .related::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 80% 20%, rgba(174, 255, 0, 0.22), transparent 28%);
  }

  .related .container {
    position: relative;
  }

  .related h2 {
    font-size: clamp(2rem, 4vw, 3.4rem);
  }

  .related__body { max-width: 720px; color: rgba(255,255,255,.82); font-size: 1.08rem; line-height: 1.7; margin: 0 0 24px; }

  .links {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
</style>
