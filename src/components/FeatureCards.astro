---
const features = [
  {
    title: 'Pénzügyek és számlázás',
    body: 'Számlázási folyamatok, státuszok és pénzügyi teendők egy helyen.',
  },
  {
    title: 'Átlátható ügyfélnyilvántartás / CRM',
    body: 'Ügyféladatok, kapcsolódó dokumentumok és következő lépések átlátható nézetben.',
  },
  {
    title: 'Gyorsított adminisztráció',
    body: 'Kevesebb manuális munka, több automatizált emlékeztető és gyorsabb döntési pont.',
  },
];
---
<section id="megoldásaink" class="section features light">
  <div class="container">
    <span class="eyebrow">Megoldásaink</span>
    <h2>Egy rendszer a napi működés kulcspontjaira.</h2>
    <div class="grid">
      {
        features.map((feature, index) => (
          <article class="card">
            <div class="num">
              0{index + 1}
            </div>
            <h3>
              {feature.title}
            </h3>
            <p>
              {feature.body}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
<style>.features h2{max-width:850px}.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--card-gap);margin-top:26px}.card{padding:var(--card-padding)}.num{width:42px;height:42px;border-radius:14px;background:var(--color-navy);color:var(--color-neon);display:grid;place-items:center;font-weight:800;margin-bottom:18px}h3{color:var(--color-navy);font-size:var(--text-card-title)}@media(max-width:860px){.grid{grid-template-columns:1fr}}</style>
