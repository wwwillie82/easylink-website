---
import GenericPublicPageRenderer from './GenericPublicPageRenderer.astro';
import { isSupportedPublicPageType, unsupportedPublicPageTypeError } from './registry';
import type { PublicPageRendererProps } from './types';
type Props = PublicPageRendererProps;
const { page, routeIndex, mode } = Astro.props;
if (!isSupportedPublicPageType(page.type)) throw unsupportedPublicPageTypeError(page.type);
---
<GenericPublicPageRenderer page={page} routeIndex={routeIndex} mode={mode} />
