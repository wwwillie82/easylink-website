---
import type { PublicPageRendererProps } from './types';
import PageHero from '@/components/PageHero.astro';
import ListingCards from '@/components/ListingCards.astro';
import ContentBlocks from '@/components/ContentBlocks.astro';
import CTASection from '@/components/CTASection.astro';
import { publicCardsFromItems } from '@/lib/content/block-contracts.mjs';
import { findRoleBlock, withoutBlocks } from '@/lib/content/blockRoles';
import { resolvePageCtaBlock } from '@/lib/content/pageCta';
type Props = PublicPageRendererProps;
const { page, routeIndex } = Astro.props;
const introBlock = findRoleBlock(page?.blocks, 'integrations-intro', (block) => block.type === 'text');
const importantBlock = findRoleBlock(page?.blocks, 'integrations-important', (block) => block.type === 'text' && block !== introBlock);
const cardsBlock = findRoleBlock(page?.blocks, 'integrations-cards', (block) => ['cards', 'card-grid'].includes(block.type));
const cardsVm = cardsBlock ? publicCardsFromItems(cardsBlock.items ?? [], { pages: routeIndex?.pages || [] }) : null;
const ctaSectionBlock = resolvePageCtaBlock(page?.blocks, { role: 'cta-section' });
const remainingBlocks = withoutBlocks(page?.blocks, [introBlock, cardsBlock, importantBlock, ctaSectionBlock]);
const hasNetworkContent = Boolean(introBlock || cardsVm?.cards?.length || importantBlock);
---
<PageHero eyebrow={page?.heroEyebrow ?? "integraciok"} title={page?.heroTitle ?? "Integrációk"} description={page?.heroDescription ?? "Az integrációs registry előkészíti a későbbi partner- és adatkapcsolati tartalmakat. Ahol nincs bizonyított éles kapcsolat, ott integrációs irányként kommunikálunk."} asset={page?.heroAsset || "/assets/nati/hero-bg-flow-02.webp"} height={page?.heroHeight} imageFit={page?.heroImageFit} imagePositionX={page?.heroImagePositionX} imagePositionY={page?.heroImagePositionY} imagePositionMobileX={page?.heroImagePositionMobileX} imagePositionMobileY={page?.heroImagePositionMobileY} overlayStrength={page?.heroOverlayStrength} imageScale={page?.heroImageScale} video={page?.heroVideo} />
{hasNetworkContent && <section class="section light network-section">
  {introBlock && <div class="container intro">{introBlock.title && <span class="eyebrow">{introBlock.title}</span>}{introBlock.body && <h2>{introBlock.body}</h2>}</div>}
  {cardsVm?.cards?.length > 0 && <div class="container"><ListingCards items={cardsVm.cards} /></div>}
  {importantBlock && <div class="container"><article class="important card">{importantBlock.title && <span class="eyebrow">{importantBlock.title}</span>}{importantBlock.body && <p>{importantBlock.body}</p>}</article></div>}
</section>}
{remainingBlocks.length > 0 && <ContentBlocks blocks={remainingBlocks} routeIndex={routeIndex} />}
<CTASection block={ctaSectionBlock} />
<style>
  .light { background: var(--color-soft); }
  .network-section { background: linear-gradient(180deg, #f6f8f5, #fff); }
  .intro { margin-bottom: 28px; }
  .intro h2 { max-width: 920px; color: var(--color-navy); font-size: clamp(1.65rem, 2.5vw, 2.4rem); }
  .important { margin-top: 28px; padding: 28px; border-radius: 24px; background: #fff; box-shadow: 0 20px 60px rgba(15,17,89,.09); }
  .important p { max-width: 920px; color: var(--color-navy); font-weight: 700; }
</style>
