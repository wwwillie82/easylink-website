---
import type { PublicPageRendererProps } from './types';
import PageHero from '@/components/PageHero.astro';
import ListingCards from '@/components/ListingCards.astro';
import ContentBlocks from '@/components/ContentBlocks.astro';
import CTASection from '@/components/CTASection.astro';
import { publishedSolutions } from '@/content/solutions';
import { findRoleBlock, withoutBlocks } from '@/lib/content/blockRoles';
import { resolveListingCards } from '@/lib/content/public-pages';
type Props = PublicPageRendererProps;
const { page, routeIndex, mode } = Astro.props;
const cardsBlock = findRoleBlock(page?.blocks, 'golden-cards', (block) => ['cards', 'card-grid'].includes(block.type));
const rawSolutionCards = cardsBlock?.items?.length ? cardsBlock.items : publishedSolutions;
const solutionCards = resolveListingCards({ items: rawSolutionCards, detailType: 'solution_detail', index: routeIndex, sourcePage: page, blockLabel: cardsBlock?.blockKey ?? cardsBlock?.block_key ?? 'golden-cards', mode, source: cardsBlock?.items?.length ? 'db-block' : 'golden' });
const ctaSectionBlock = findRoleBlock(page?.blocks, 'cta-section', (block) => block.type === 'cta');
const remainingBlocks = withoutBlocks(page?.blocks, [cardsBlock, ctaSectionBlock]);
---
<PageHero eyebrow={page?.heroEyebrow ?? "megoldasaink"} title={page?.heroTitle ?? "Megoldásaink"} description={page?.heroDescription ?? "Válaszd ki, melyik működési területet szeretnéd átláthatóbbá tenni: pénzügy, HR, CRM, dokumentumkezelés, kontrolling vagy AI támogatás."} asset={page?.heroAsset || undefined} height={page?.heroHeight} imageFit={page?.heroImageFit} imagePositionX={page?.heroImagePositionX} imagePositionY={page?.heroImagePositionY} imagePositionMobileX={page?.heroImagePositionMobileX} imagePositionMobileY={page?.heroImagePositionMobileY} overlayStrength={page?.heroOverlayStrength} imageScale={page?.heroImageScale} video={page?.heroVideo} />
<section class="section light"><div class="container"><ListingCards items={solutionCards} /></div></section>
{remainingBlocks.length > 0 && <ContentBlocks blocks={remainingBlocks} />}
<CTASection block={ctaSectionBlock} />
<style>.light { background: var(--color-soft); }</style>
