---
import type { PublicPageRendererProps } from './types';
import PageHero from '@/components/PageHero.astro';
import ContentBlocks from '@/components/ContentBlocks.astro';
import CTASection from '@/components/CTASection.astro';
import { normalizePublicHref, publicHrefRel, publicHrefTarget } from '@/lib/content/links';
import { safeContactIntro } from '@/lib/content/contact.mjs';
import { findRoleBlock, withoutBlocks } from '@/lib/content/blockRoles';
import { resolvePageCtaBlock } from '@/lib/content/pageCta';
type Props = PublicPageRendererProps;
const { page, routeIndex } = Astro.props;
const ctaBlock = findRoleBlock(page?.blocks, 'contact-main', (block) => block.type === 'cta' || block.type === 'text');
const featureBlock = findRoleBlock(page?.blocks, 'contact-features', (block) => block.type === 'feature-list');
const contactCta = ctaBlock?.items?.[0] ?? null;
const contactIntro = safeContactIntro(ctaBlock?.body) || String(ctaBlock?.body ?? '').trim();
const primaryHref = normalizePublicHref(contactCta?.url || '');
const secondaryHref = normalizePublicHref(contactCta?.secondaryUrl || '');
const primaryIsEmail = primaryHref.startsWith('mailto:');
const helpItems = featureBlock?.items?.length ? featureBlock.items : ['Megnézzük, mely modulok illenek a jelenlegi működésedhez.', 'Átbeszéljük a hotel/szálláshely, vendéglátó vagy szolgáltatói fókuszt.', 'Összegyűjtjük, milyen integrációs irányokat érdemes előkészíteni.'];
const ctaSectionBlock = resolvePageCtaBlock(page?.blocks, { role: 'cta-section' });
const remainingBlocks = withoutBlocks(page?.blocks, [ctaBlock, featureBlock, ctaSectionBlock]);
const hasContactContent = Boolean(ctaBlock || featureBlock);
---
<PageHero eyebrow={page?.heroEyebrow ?? "Kapcsolat"} title={page?.heroTitle ?? "Kapcsolódjunk össze."} description={page?.heroDescription ?? "Kérj bemutatót vagy egyeztetést az Easylink bevezetési lehetőségeiről."} asset={page?.heroAsset || undefined} height={page?.heroHeight} imageFit={page?.heroImageFit} imagePositionX={page?.heroImagePositionX} imagePositionY={page?.heroImagePositionY} imagePositionMobileX={page?.heroImagePositionMobileX} imagePositionMobileY={page?.heroImagePositionMobileY} overlayStrength={page?.heroOverlayStrength} imageScale={page?.heroImageScale} video={page?.heroVideo} />
{hasContactContent && <section class="section light"><div class="container contact-grid">
  {ctaBlock && <article class="card polished contact">{contactCta?.eyebrow && <span class="eyebrow">{contactCta.eyebrow}</span>}{ctaBlock.title && <h2>{ctaBlock.title}</h2>}{contactIntro && <p class="contact-copy">{contactIntro}</p>}{((primaryHref && contactCta?.label) || (secondaryHref && contactCta?.secondaryLabel)) && <div class="contact-actions">{primaryHref && contactCta?.label && (primaryIsEmail ? <a class="button button-primary" href={primaryHref} target={publicHrefTarget(primaryHref)} rel={publicHrefRel(primaryHref)} data-easylink-cta="email" data-easylink-cta-id="contact-page-email" data-easylink-cta-slot="contact-page">{contactCta.label}</a> : <a class="button button-primary" href={primaryHref} target={publicHrefTarget(primaryHref)} rel={publicHrefRel(primaryHref)} data-easylink-cta="demo" data-easylink-cta-id="contact-page-primary" data-easylink-cta-slot="contact-page">{contactCta.label}</a>)}{secondaryHref && contactCta?.secondaryLabel && <a class="button button-secondary" href={secondaryHref} target={publicHrefTarget(secondaryHref)} rel={publicHrefRel(secondaryHref)}>{contactCta.secondaryLabel}</a>}</div>}</article>}
  {featureBlock && <article class="card polished contact"><h2>{featureBlock.title || 'Miben tudunk segíteni?'}</h2><ul>{helpItems.map((item) => <li>{item}</li>)}</ul></article>}
</div></section>}
{remainingBlocks.length > 0 && <ContentBlocks blocks={remainingBlocks} routeIndex={routeIndex} />}
<CTASection block={ctaSectionBlock} />
<style>
  .light { background: var(--color-soft); }
  .contact-grid { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 22px; }
  .contact { padding: 34px; border-radius: 28px; box-shadow: 0 22px 70px rgba(15,17,89,.1); }
  .contact h2 { color: var(--color-navy); font-size: clamp(1.8rem, 4vw, 3rem); }
  .contact-copy { white-space: pre-line; }
  .contact-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 20px; }
  li { margin: 12px 0; color: var(--color-navy); line-height: 1.55; font-weight: 600; }
  @media (max-width: 860px) { .contact-grid { grid-template-columns: 1fr; } }
</style>
