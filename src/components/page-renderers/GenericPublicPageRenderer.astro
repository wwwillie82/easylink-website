---
import type { PublicPageRendererProps } from './types';
import PageHero from '@/components/PageHero.astro';
import CTASection from '@/components/CTASection.astro';
import PublicSection from '@/components/PublicSection.astro';
import { resolvePageCtaBlock } from '@/lib/content/pageCta';
import { composePublicSections, pageHeroVariant } from '@/lib/content/section-composition.mjs';
type Props = PublicPageRendererProps;
const { page, routeIndex } = Astro.props;
const ctaSectionBlock = resolvePageCtaBlock(page?.blocks);
const sections = composePublicSections(page?.blocks || []);
const heroVariant = pageHeroVariant(page);
---
<PageHero eyebrow={page?.heroEyebrow} title={page?.heroTitle} description={page?.heroDescription} variant={heroVariant} asset={page?.heroAsset || undefined} height={page?.heroHeight} imageFit={page?.heroImageFit} imagePositionX={page?.heroImagePositionX} imagePositionY={page?.heroImagePositionY} imagePositionMobileX={page?.heroImagePositionMobileX} imagePositionMobileY={page?.heroImagePositionMobileY} overlayStrength={page?.heroOverlayStrength} imageScale={page?.heroImageScale} video={page?.heroVideo} />
{sections.map((section) => <PublicSection section={section} routeIndex={routeIndex} />)}
<CTASection block={ctaSectionBlock} />
