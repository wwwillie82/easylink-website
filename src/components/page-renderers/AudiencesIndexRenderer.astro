---
import type { PublicPageRendererProps } from './types';
import PageHero from '@/components/PageHero.astro';
import ListingCards from '@/components/ListingCards.astro';
import ContentBlocks from '@/components/ContentBlocks.astro';
import CTASection from '@/components/CTASection.astro';
import { publishedAudiences } from '@/content/audiences';
import { findRoleBlock, withoutBlocks } from '@/lib/content/blockRoles';
import { resolvePageCtaBlock } from '@/lib/content/pageCta';
import { resolveListingCards } from '@/lib/content/public-pages';
type Props = PublicPageRendererProps;
const { page, routeIndex, mode } = Astro.props;
const cardsBlock = findRoleBlock(page?.blocks, 'golden-cards', (block) => ['cards', 'card-grid'].includes(block.type));
const rawAudienceCards = cardsBlock?.items?.length ? cardsBlock.items : publishedAudiences;
const audienceCards = resolveListingCards({ items: rawAudienceCards, detailType: 'audience_detail', index: routeIndex, sourcePage: page, blockLabel: cardsBlock?.blockKey ?? cardsBlock?.block_key ?? 'golden-cards', mode, source: cardsBlock?.items?.length ? 'db-block' : 'golden' });
const ctaSectionBlock = resolvePageCtaBlock(page?.blocks, { role: 'cta-section' });
const remainingBlocks = withoutBlocks(page?.blocks, [cardsBlock, ctaSectionBlock]);
---
<PageHero eyebrow={page?.heroEyebrow ?? "kinek-szol"} title={page?.heroTitle ?? "Kinek szól?"} description={page?.heroDescription ?? "A public site külön route-okon mutatja be, mely vállalkozásoknak ad könnyebb cégvezetést az Easylink."} asset={page?.heroAsset || undefined} height={page?.heroHeight} imageFit={page?.heroImageFit} imagePositionX={page?.heroImagePositionX} imagePositionY={page?.heroImagePositionY} imagePositionMobileX={page?.heroImagePositionMobileX} imagePositionMobileY={page?.heroImagePositionMobileY} overlayStrength={page?.heroOverlayStrength} imageScale={page?.heroImageScale} video={page?.heroVideo} />
<section class="section light"><div class="container"><ListingCards items={audienceCards} /></div></section>
{remainingBlocks.length > 0 && <ContentBlocks blocks={remainingBlocks} />}
<CTASection block={ctaSectionBlock} />
<style>.light { background: var(--color-soft); }</style>
