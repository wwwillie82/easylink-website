---
import type { PublicPageRendererProps } from './types';
import PageHero from '@/components/PageHero.astro';
import ContentBlocks from '@/components/ContentBlocks.astro';
import CTASection from '@/components/CTASection.astro';
import { findRoleBlock, withoutBlocks } from '@/lib/content/blockRoles';
import { resolvePageCtaBlock } from '@/lib/content/pageCta';
type Props = PublicPageRendererProps;
const { page, routeIndex } = Astro.props;
const ctaSectionBlock = resolvePageCtaBlock(page.blocks, { role: 'cta-section' });
const contentBlocks = withoutBlocks(page.blocks, [ctaSectionBlock]);
---
<PageHero eyebrow={page.heroEyebrow} title={page.heroTitle} description={page.heroDescription} asset={page.heroAsset || undefined} height={page.heroHeight} imageFit={page.heroImageFit} imagePositionX={page.heroImagePositionX} imagePositionY={page.heroImagePositionY} imagePositionMobileX={page.heroImagePositionMobileX} imagePositionMobileY={page.heroImagePositionMobileY} overlayStrength={page.heroOverlayStrength} imageScale={page.heroImageScale} video={page.heroVideo} />
<ContentBlocks blocks={contentBlocks} routeIndex={routeIndex} />
<CTASection block={ctaSectionBlock} />
