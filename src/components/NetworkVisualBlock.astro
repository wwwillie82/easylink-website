---
import { normalizePublicHref, publicHrefRel, publicHrefTarget } from '@/lib/content/links';
import { normalizeNetworkVisualItems } from '@/lib/content/network-visual.mjs';
const { block = {} } = Astro.props;
const { config, legacyItems, isLegacy } = normalizeNetworkVisualItems(block.items);
const title = block.title || 'Adatkapcsolati ábra';
const stableSource = String(block.id || block.block_key || `${block.type || 'network-visual'}-${block.title || 'block'}-${block.sort_order ?? ''}`);
const stableId = stableSource.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9_-]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 72) || 'network-visual';
const descId = `network-${stableId}-desc`;
const arrowId = `network-${stableId}-arrow`;
const arrowStartId = `network-${stableId}-arrow-start`;
const width = 920, height = config?.layout === 'flow' ? 360 : 520;
const nodes = config?.nodes || [];
const core = nodes.find((n) => n.kind === 'core') || nodes[0];
const outer = nodes.filter((n) => n.id !== core?.id);
const pos = new Map();
if (config?.layout === 'flow') nodes.forEach((n, i) => pos.set(n.id, { x: 110 + (nodes.length <= 1 ? 0 : i * (700 / (nodes.length - 1))), y: 180 + ((i % 2) ? 58 : -58) }));
else { if (core) pos.set(core.id, { x: 460, y: 260 }); outer.forEach((n, i) => { const a = -Math.PI / 2 + (i * 2 * Math.PI / Math.max(outer.length, 1)); pos.set(n.id, { x: 460 + Math.cos(a) * 285, y: 260 + Math.sin(a) * 170 }); }); }
const dirText = { none: 'irányjelölés nélkül', forward: 'egyirányú', backward: 'visszafelé irányuló', both: 'kétirányú' };
const kindText = { core: 'központi rendszer', module: 'modul', external: 'külső rendszer', 'data-source': 'adatforrás', ai: 'AI komponens', user: 'felhasználó' };
const markerStart = (d) => d === 'backward' || d === 'both' ? `url(#${arrowStartId})` : undefined;
const markerEnd = (d) => d === 'forward' || d === 'both' ? `url(#${arrowId})` : undefined;
---
<article class="content-card type-network-visual network-visual-card" data-network-visual-block data-layout={config?.layout || 'legacy'}>
  <header class="network-header"><span class="eyebrow">ADATKAPCSOLAT</span><h2>{title}</h2>{block.body && <p>{block.body}</p>}</header>
  {isLegacy ? <div class="network-legacy" data-network-legacy-fallback><p>Régi listás formátum</p>{legacyItems.length > 0 && <ul>{legacyItems.map((item) => <li>{item.label}</li>)}</ul>}</div> : nodes.length > 0 && <>
    <figure class="network-svg-wrap">
      <svg viewBox={`0 0 ${width} ${height}`} role="img" aria-labelledby={`${descId}-title ${descId}`} data-network-svg data-network-layout={config.layout}>
        <title id={`${descId}-title`}>{title}</title><desc id={descId}>{config.layout === 'flow' ? 'Balról jobbra rendezett adatáramlási ábra.' : 'Központi hub köré rendezett kapcsolati ábra.'}</desc>
        <defs><marker id={arrowId} viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse"><path d="M 0 0 L 10 5 L 0 10 z" /></marker><marker id={arrowStartId} viewBox="0 0 10 10" refX="1" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse"><path d="M 10 0 L 0 5 L 10 10 z" /></marker></defs>
        {config.edges.map((e) => { const a = pos.get(e.from), b = pos.get(e.to); if (!a || !b) return null; const mid = { x: (a.x + b.x) / 2, y: (a.y + b.y) / 2 }; return <g class:list={['network-edge', `is-${e.direction}`]} data-edge-direction={e.direction}><line x1={a.x} y1={a.y} x2={b.x} y2={b.y} marker-start={markerStart(e.direction)} marker-end={markerEnd(e.direction)} />{e.label && <text x={mid.x} y={mid.y - 8}>{e.label}</text>}</g>; })}
        {nodes.map((n) => { const p = pos.get(n.id); const href = normalizePublicHref(n.href); const content = <g class:list={['network-node', `is-${n.kind}`]} tabindex="0" data-node-kind={n.kind}><circle cx={p.x} cy={p.y} r={n.kind === 'core' ? 54 : 44} /><text x={p.x} y={p.y - 3} text-anchor="middle">{n.label}</text><text x={p.x} y={p.y + 17} text-anchor="middle" class="kind">{kindText[n.kind]}</text></g>; return href ? <a href={href} target={publicHrefTarget(href)} rel={publicHrefRel(href)}>{content}</a> : content; })}
      </svg>
    </figure>
    {config.showLegend && <ul class="network-legend" data-network-legend>{Object.entries(kindText).map(([kind, label]) => <li><span class={`dot is-${kind}`}></span>{label}</li>)}</ul>}
    <section class="network-a11y-list" aria-label="Kapcsolatok szöveges listája" data-network-accessible-list><h3>Kapcsolatok</h3><ul>{config.edges.map((e) => { const from = nodes.find((n) => n.id === e.from)?.label || e.from; const to = nodes.find((n) => n.id === e.to)?.label || e.to; return <li>{from} → {to}: {e.label || 'kapcsolat'} ({dirText[e.direction]})</li>; })}</ul></section>
  </>}
</article>
<style>
.network-visual-card{grid-column:1/-1;padding:clamp(24px,4vw,42px);background:radial-gradient(circle at top right,rgba(46,229,255,.22),transparent 34%),linear-gradient(135deg,#07102f,#050826 58%,#020416);color:#fff;border-color:rgba(46,229,255,.34)}.network-header h2{color:#fff}.network-header p{color:rgba(255,255,255,.82)}.network-svg-wrap{margin:24px 0 0}.network-svg-wrap svg{width:100%;height:auto;display:block;overflow:visible}.network-edge line{stroke:#83f2ff;stroke-width:3;stroke-dasharray:0;opacity:.78}.network-edge.is-none line{stroke-dasharray:7 8}.network-edge.is-backward line{stroke:#ffd36e}.network-edge.is-both line{stroke:#8dffbf;stroke-width:4}.network-edge path{fill:#83f2ff}.network-edge text{fill:#eaffff;font-size:18px;font-weight:800;paint-order:stroke;stroke:#06102c;stroke-width:5px}.network-node circle{fill:#10235f;stroke:#7ee7ff;stroke-width:3}.network-node.is-core circle{fill:#071a42;stroke:#b6ff3b;stroke-width:5}.network-node.is-external circle{stroke:#ffd36e}.network-node.is-data-source circle{stroke:#8dffbf}.network-node.is-ai circle{stroke:#e8a6ff}.network-node.is-user circle{stroke:#fff}.network-node text{fill:#fff;font-weight:900;font-size:18px}.network-node .kind{fill:#d9fbff;font-size:11px;text-transform:uppercase;letter-spacing:.06em}.network-node:hover circle,.network-node:focus circle{filter:drop-shadow(0 0 12px rgba(46,229,255,.75));stroke-width:6}.network-legend{display:flex;flex-wrap:wrap;gap:10px 18px;margin:18px 0 0;padding:0;list-style:none}.network-legend li{color:#fff;margin:0}.dot{display:inline-block;width:12px;height:12px;border:2px solid #7ee7ff;border-radius:99px;margin-right:8px}.network-a11y-list{margin-top:20px;border-top:1px solid rgba(255,255,255,.16);padding-top:16px}.network-a11y-list h3{color:#fff;font-size:1rem}.network-a11y-list li,.network-legacy li{color:rgba(255,255,255,.92)}@media(max-width:700px){.network-svg-wrap{display:none}.network-legend{display:none}.network-a11y-list{display:block}.network-visual-card{padding:22px}.network-a11y-list ul{padding-left:18px}}
</style>
