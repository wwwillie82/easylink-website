---
import { normalizePublicHref, publicHrefRel, publicHrefTarget } from '@/lib/content/links';
import { normalizeNetworkVisualItems } from '@/lib/content/network-visual.mjs';
const { block = {} } = Astro.props;
const { config, legacyItems, isLegacy } = normalizeNetworkVisualItems(block.items);
const title = String(block.title || '').trim();
const eyebrow = String(block.eyebrow || '').trim();
const stableSource = String(block.id || block.block_key || `${block.type || 'network-visual'}-${block.title || 'block'}-${block.sort_order ?? ''}`);
const stableId = stableSource.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9_-]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 72) || 'network-visual';
const descId = `network-${stableId}-desc`;
const arrowId = `network-${stableId}-arrow`;
const arrowStartId = `network-${stableId}-arrow-start`;
const isFlow = config?.layout === 'flow';
const width = isFlow ? 1560 : 1240;
const height = isFlow ? 840 : 760;
const nodeWidth = 176;
const nodeHeight = 92;
const coreWidth = 230;
const coreHeight = 118;
const edgeLabelBoxWidth = 164;
const edgeLabelPaddingY = 8;
const edgeLabelLineHeight = 14;
const nodes = config?.nodes || [];
const core = nodes.find((n) => n.kind === 'core') || nodes[0];
const outer = nodes.filter((n) => n.id !== core?.id);
const truncateLabel = (label = '', maxChars = 22) => {
  const value = String(label || '').trim();
  return value.length > maxChars ? `${value.slice(0, Math.max(0, maxChars - 1)).trimEnd()}…` : value;
};
const splitLabelLines = (label = '', maxChars = 15, maxLines = 2) => {
  const value = String(label || '').trim().replace(/\s+/g, ' ');
  if (!value) return [''];
  const words = value.split(' ');
  const lines = [];
  let line = '';
  words.forEach((word) => {
    const candidate = line ? `${line} ${word}` : word;
    if (candidate.length <= maxChars) line = candidate;
    else {
      if (line) lines.push(line);
      line = word;
    }
  });
  if (line) lines.push(line);
  const limited = lines.flatMap((line) => line.length > maxChars + 4 ? line.match(new RegExp(`.{1,${maxChars}}`, 'g')) || [line] : [line]).slice(0, maxLines);
  const sourceTooLong = limited.join(' ').length < value.length || lines.length > maxLines;
  if (sourceTooLong && limited.length) limited[limited.length - 1] = truncateLabel(limited[limited.length - 1], maxChars);
  return limited.length ? limited : [truncateLabel(value, maxChars)];
};
const safeSvgText = (value = '') => String(value || '').replace(/[\u0000-\u001f\u007f]/g, '').trim();

const kindLabel = (kind) => safeSvgText(kindText[kind] || kind || '').toLocaleUpperCase('hu-HU');
const splitEdgeLabelLines = (label = '', maxCharsPerLine = 15, maxLines = 2) => splitLabelLines(label, maxCharsPerLine, maxLines);

const svgEdges = config?.edges || [];
const hasHiddenFlowEdges = false;
const nodeSize = (node) => node?.kind === 'core' ? { width: coreWidth, height: coreHeight } : { width: nodeWidth, height: nodeHeight };
const pos = new Map();
if (isFlow) {
  const flowSlots = [
    { name: 'left-middle', x: 300, y: 420, preferred: ['core', 'user', 'data-source'] },
    { name: 'mid-top', x: 675, y: 160, preferred: ['module', 'data-source'] },
    { name: 'mid-bottom', x: 675, y: 690, preferred: ['module', 'data-source'] },
    { name: 'right-top', x: 1045, y: 190, preferred: ['module'] },
    { name: 'right-middle', x: 1045, y: 455, preferred: ['module'] },
    { name: 'right-bottom', x: 1045, y: 675, preferred: ['module'] },
    { name: 'far-right-top', x: 1340, y: 225, preferred: ['ai', 'external'] },
    { name: 'far-right-bottom', x: 1340, y: 595, preferred: ['external', 'ai'] },
    { name: 'left-top', x: 270, y: 155, preferred: ['user', 'data-source'] },
    { name: 'left-bottom', x: 270, y: 690, preferred: ['data-source', 'user'] },
    { name: 'far-right-middle', x: 1355, y: 415, preferred: ['external', 'ai'] },
    { name: 'mid-middle', x: 690, y: 425, preferred: ['module'] },
  ];
  const claimedSlots = new Set();
  const claimSlot = (node, fallbackIndex) => {
    const preferred = flowSlots.find((slot) => !claimedSlots.has(slot.name) && slot.preferred.includes(node.kind));
    if (preferred) {
      claimedSlots.add(preferred.name);
      return preferred;
    }
    const remaining = flowSlots.filter((slot) => !claimedSlots.has(slot.name));
    const slot = remaining[0] || flowSlots[fallbackIndex % flowSlots.length];
    claimedSlots.add(slot.name);
    return slot;
  };
  const orderedNodes = [
    ...nodes.filter((n) => n.kind === 'core'),
    ...nodes.filter((n) => n.kind === 'module'),
    ...nodes.filter((n) => n.kind === 'ai'),
    ...nodes.filter((n) => n.kind === 'external'),
    ...nodes.filter((n) => !['core', 'module', 'ai', 'external'].includes(n.kind)),
  ];
  orderedNodes.forEach((n, i) => {
    const slot = claimSlot(n, i);
    const overflow = Math.floor(i / flowSlots.length);
    pos.set(n.id, { x: slot.x + overflow * 28, y: slot.y + overflow * (i % 2 ? 32 : -32) });
  });
} else {
  if (core) pos.set(core.id, { x: 620, y: 380 });
  outer.forEach((n, i) => {
    const a = -Math.PI / 2 + (i * 2 * Math.PI / Math.max(outer.length, 1));
    pos.set(n.id, { x: 620 + Math.cos(a) * 500, y: 380 + Math.sin(a) * 320 });
  });
}
const nodeEdgePoint = (from, to, node) => {
  const size = nodeSize(node);
  const dx = to.x - from.x;
  const dy = to.y - from.y;
  const scale = Math.min(Math.abs(dx) > 0 ? (size.width / 2 + 16) / Math.abs(dx) : Infinity, Math.abs(dy) > 0 ? (size.height / 2 + 16) / Math.abs(dy) : Infinity);
  return { x: from.x + dx * scale, y: from.y + dy * scale };
};
const edgePath = (edge, index) => {
  const fromNode = nodes.find((n) => n.id === edge.from);
  const toNode = nodes.find((n) => n.id === edge.to);
  const a = pos.get(edge.from), b = pos.get(edge.to);
  if (!a || !b || !fromNode || !toNode) return null;
  const start = nodeEdgePoint(a, b, fromNode);
  const end = nodeEdgePoint(b, a, toNode);
  if (isFlow) {
    const direction = Math.sign(end.x - start.x) || 1;
    const distance = Math.abs(end.x - start.x);
    const sweep = ((index % 7) - 3) * 42 + (distance > 520 ? (index % 2 ? 34 : -34) : 0);
    const c1x = start.x + direction * Math.max(130, distance * 0.44);
    const c2x = end.x - direction * Math.max(130, distance * 0.44);
    const dx = end.x - start.x;
    const dy = end.y - start.y;
    const len = Math.hypot(dx, dy) || 1;
    const normal = { x: -dy / len, y: dx / len };
    const labelT = distance > 650 ? (index % 2 ? 0.35 : 0.65) : (index % 3 === 0 ? 0.42 : 0.58);
    const labelBase = { x: start.x + dx * labelT, y: start.y + dy * labelT };
    const labelOffset = (index % 2 ? 1 : -1) * (72 + Math.min(46, distance * 0.06));
    const label = { x: labelBase.x + normal.x * labelOffset, y: labelBase.y + normal.y * labelOffset + sweep * 0.18 };
    return { d: `M ${start.x} ${start.y} C ${c1x} ${start.y + sweep}, ${c2x} ${end.y - sweep}, ${end.x} ${end.y}`, label };
  }
  const towardOuter = fromNode.id === core?.id ? 0.84 : toNode.id === core?.id ? 0.16 : 0.72;
  const lx = start.x + (end.x - start.x) * towardOuter;
  const ly = start.y + (end.y - start.y) * towardOuter;
  const dx = end.x - start.x;
  const dy = end.y - start.y;
  const len = Math.hypot(dx, dy) || 1;
  const offset = (index % 2 ? 1 : -1) * 42;
  return { d: `M ${start.x} ${start.y} L ${end.x} ${end.y}`, label: { x: lx + (-dy / len) * offset, y: ly + (dx / len) * offset } };
};
const dirText = { none: 'irányjelölés nélkül', forward: 'egyirányú', backward: 'visszafelé irányuló', both: 'kétirányú' };
const kindText = { core: 'központi rendszer', module: 'modul', external: 'külső rendszer', 'data-source': 'adatforrás', ai: 'AI komponens', user: 'felhasználó' };
const markerStart = (d) => d === 'backward' || d === 'both' ? `url(#${arrowStartId})` : undefined;
const markerEnd = (d) => d === 'forward' || d === 'both' ? `url(#${arrowId})` : undefined;
---
<article class="content-card type-network-visual network-visual-card" data-network-visual-block data-layout={config?.layout || 'legacy'}>
  {(eyebrow || title || block.body) && <header class="network-header">{eyebrow && <span class="eyebrow">{eyebrow}</span>}{title && <h2>{title}</h2>}{block.body && <p>{block.body}</p>}</header>}
  {isLegacy ? <div class="network-legacy" data-network-legacy-fallback><p>Régi listás formátum</p>{legacyItems.length > 0 && <ul>{legacyItems.map((item) => <li>{item.label}</li>)}</ul>}</div> : nodes.length > 0 && <>
    <figure class="network-svg-wrap">
      <svg viewBox={`0 0 ${width} ${height}`} role="img" aria-labelledby={`${descId}-title ${descId}`} data-network-svg data-network-layout={config.layout}>
        {title && <title id={`${descId}-title`}>{title}</title>}<desc id={descId}>{config.layout === 'flow' ? 'Balról jobbra rendezett adatáramlási ábra.' : 'Központi hub köré rendezett kapcsolati ábra.'}</desc>
        <defs><marker id={arrowId} viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse"><path d="M 0 0 L 10 5 L 0 10 z" fill="context-stroke" /></marker><marker id={arrowStartId} viewBox="0 0 10 10" refX="1" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse"><path d="M 10 0 L 0 5 L 10 10 z" fill="context-stroke" /></marker></defs>
        {svgEdges.map((e, i) => { const edge = edgePath(e, e.originalIndex ?? i); if (!edge) return null; const labelLines = safeSvgText(e.label) ? splitEdgeLabelLines(safeSvgText(e.label), 15, 2) : []; const labelHeight = labelLines.length ? (edgeLabelPaddingY * 2 + labelLines.length * edgeLabelLineHeight) : 0; return <g class:list={['network-edge', `is-${e.direction}`]} data-edge-direction={e.direction}><path d={edge.d} marker-start={markerStart(e.direction)} marker-end={markerEnd(e.direction)} />{labelLines.length > 0 && <g class="edge-label" aria-hidden="true"><rect x={edge.label.x - edgeLabelBoxWidth / 2} y={edge.label.y - labelHeight / 2} width={edgeLabelBoxWidth} height={labelHeight} rx="14" /><text x={edge.label.x} y={edge.label.y - ((labelLines.length - 1) * edgeLabelLineHeight) / 2}>{labelLines.map((line, index) => <tspan x={edge.label.x} dy={index === 0 ? 0 : edgeLabelLineHeight}>{line}</tspan>)}</text></g>}</g>; })}
        {nodes.map((n) => { const p = pos.get(n.id); if (!p) return null; const href = normalizePublicHref(n.href); const size = nodeSize(n); const lines = splitLabelLines(safeSvgText(n.label), n.kind === 'core' ? 20 : 17, 2); const kind = kindLabel(n.kind); const content = <g class:list={['network-node', `is-${n.kind}`]} tabindex="0" data-node-kind={n.kind}><title>{n.label}</title><rect class="node-card" x={p.x - size.width / 2} y={p.y - size.height / 2} width={size.width} height={size.height} rx={n.kind === 'core' ? 26 : 22} /><text class="node-label" x={p.x} y={p.y - (lines.length > 1 ? 17 : 8)} text-anchor="middle">{lines.map((line, index) => <tspan x={p.x} dy={index === 0 ? 0 : 17}>{line}</tspan>)}</text><text x={p.x} y={p.y + size.height / 2 - 18} text-anchor="middle" class="kind">{kind}</text></g>; return href ? <a href={href} target={publicHrefTarget(href)} rel={publicHrefRel(href)}>{content}</a> : content; })}
      </svg>
    </figure>
    {hasHiddenFlowEdges && <p class="network-flow-note" data-network-flow-note>A diagram a fő kapcsolatokat emeli ki; a teljes lista lent olvasható.</p>}
    {config.showLegend && <ul class="network-legend" data-network-legend>{Object.entries(kindText).map(([kind, label]) => <li><span class={`dot is-${kind}`}></span>{label}</li>)}</ul>}
    <section class="network-a11y-list" aria-label="Kapcsolatok szöveges listája" data-network-accessible-list><h3>Kapcsolatok</h3><ul>{config.edges.map((e) => { const from = nodes.find((n) => n.id === e.from)?.label || e.from; const to = nodes.find((n) => n.id === e.to)?.label || e.to; return <li>{from} → {to}: {e.label || 'kapcsolat'} ({dirText[e.direction]})</li>; })}</ul></section>
  </>}
</article>
<style>
.network-visual-card{grid-column:1/-1;padding:clamp(24px,4vw,42px);background:radial-gradient(circle at top right,rgba(46,229,255,.22),transparent 34%),linear-gradient(135deg,#07102f,#050826 58%,#020416);color:#fff;border-color:rgba(46,229,255,.34)}.network-header h2{color:#fff}.network-header p{color:rgba(255,255,255,.82)}.network-svg-wrap{margin:28px 0 0}.network-svg-wrap svg{width:100%;height:auto;display:block;overflow:visible}.network-edge path{fill:none;stroke:#83f2ff;stroke-width:3;stroke-dasharray:0;opacity:.72}.network-edge.is-none path{stroke-dasharray:7 8}.network-edge.is-backward path{stroke:#ffd36e}.network-edge.is-both path{stroke:#8dffbf;stroke-width:4}.network-edge .edge-label rect{fill:rgba(5,12,35,.86);stroke:rgba(126,231,255,.38);stroke-width:1}.network-edge .edge-label text{fill:#eaffff;font-size:12px;font-weight:800;text-anchor:middle;dominant-baseline:middle;stroke:none}.network-node .node-card{fill:#10235f;stroke:#7ee7ff;stroke-width:3;filter:drop-shadow(0 10px 18px rgba(0,0,0,.22))}.network-node.is-core .node-card{fill:#071a42;stroke:#b6ff3b;stroke-width:5}.network-node.is-external .node-card{stroke:#ffd36e}.network-node.is-data-source .node-card{stroke:#8dffbf}.network-node.is-ai .node-card{stroke:#e8a6ff}.network-node.is-user .node-card{stroke:#fff}.network-node text{fill:#fff;font-weight:900;font-size:14px}.network-node.is-core text{font-size:15px}.network-node .kind{fill:#d9fbff;font-size:7.8px;text-transform:uppercase;letter-spacing:.035em}.network-node:hover .node-card,.network-node:focus .node-card{filter:drop-shadow(0 0 8px rgba(46,229,255,.46));stroke-width:4}.network-flow-note{margin:12px 0 0;color:rgba(255,255,255,.74);font-size:.9rem}.network-legend{display:flex;flex-wrap:wrap;gap:14px 26px;margin:22px 0 0;padding:0;list-style:none}.network-legend li{display:flex;align-items:center;color:#fff;margin:0;font-size:.88rem;line-height:1.35}.dot{display:inline-block;flex:0 0 auto;width:11px;height:11px;border:2px solid #7ee7ff;border-radius:99px;margin-right:9px}.network-a11y-list{margin-top:20px;border-top:1px solid rgba(255,255,255,.16);padding-top:16px}.network-a11y-list h3{color:#fff;font-size:1rem}.network-a11y-list li,.network-legacy li{color:rgba(255,255,255,.92)}@media(max-width:900px){.network-svg-wrap{display:none}.network-legend{display:none}.network-a11y-list{display:block}.network-visual-card{padding:22px}.network-a11y-list ul{padding-left:18px}}
</style>
