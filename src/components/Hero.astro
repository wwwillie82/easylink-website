---
const deployUrl = import.meta.env.PUBLIC_DEPLOY_URL ?? 'https://deploy.easylink.hu';
---

<section id="top" class="hero">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="container hero-grid">
    <div class="hero-copy">
      <span class="eyebrow">Easylink ügyvitel + AI</span>
      <h1>Cégvezetés, könnyedén.</h1>
      <p>
        Felejtsd el a táblázatokat! Olyan ügyviteli rendszert adunk a kezedbe, amivel egyetlen,
        átlátható felületen irányíthatod a számlázást, az adminisztrációt és az ügyfélnyilvántartást.
      </p>
      <div class="actions">
        <a class="button button-primary" href={deployUrl}>Demót kérek</a>
        <a class="button button-secondary" href={deployUrl}>Próbáld ki ingyen</a>
      </div>
      <div class="trust-row">
        <span>Számlázás</span>
        <span>Admin</span>
        <span>CRM</span>
        <span>AI válaszok</span>
      </div>
    </div>
    <div class="hero-panel" aria-hidden="true">
      <b>Vezetői pulzus</b>
      <span>12 nyitott számla</span>
      <span>4 admin teendő</span>
      <span>AI javaslat: 3 prioritás</span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    min-height: var(--home-hero-min-height);
    display: grid;
    align-items: center;
    color: white;
    background: var(--color-navy-deep);
    padding: clamp(56px, 6.5vw, 94px) 0;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(90deg, rgba(7, 8, 45, 0.95) 0%, rgba(15, 17, 89, 0.84) 36%, rgba(15, 17, 89, 0.28) 70%, rgba(7, 8, 45, 0.58) 100%),
      linear-gradient(0deg, rgba(7, 8, 45, 0.84), rgba(7, 8, 45, 0.08) 46%, rgba(7, 8, 45, 0.9)),
      url('/assets/nati/hero-bg-flow-03.webp');
    background-size: cover;
    background-position: center right;
    transform: scale(1.02);
  }
  .hero::after {
    content: "";
    position: absolute;
    inset: auto -12% -20% -12%;
    height: 260px;
    background: radial-gradient(ellipse at center, rgba(174, 255, 0, 0.18), transparent 60%);
    filter: blur(18px);
  }
  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(240px, 0.48fr);
    gap: clamp(24px, 3.5vw, 36px);
    align-items: end;
  }
  .hero-copy { max-width: 760px; }
  .hero h1 { max-width: 11ch; font-size: var(--text-home-hero-title); }
  .hero p { max-width: var(--container-reading); color: rgba(255, 255, 255, 0.82); font-size: var(--text-body-lg); }
  .actions, .trust-row { display: flex; gap: 14px; flex-wrap: wrap; }
  .actions { margin-top: 22px; }
  .trust-row { margin-top: 20px; }
  .trust-row span {
    border: 1px solid rgba(174, 255, 0, 0.28);
    background: rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    padding: 9px 13px;
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.88rem;
  }
  .hero-panel {
    padding: 20px;
    border-radius: 24px;
    background: rgba(6, 8, 39, 0.62);
    border: 1px solid rgba(174, 255, 0, 0.28);
    backdrop-filter: blur(14px);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.28);
    display: grid;
    gap: 10px;
  }
  .hero-panel b { color: var(--color-neon); }
  .hero-panel span { padding: 10px 12px; border-radius: 14px; background: rgba(255, 255, 255, 0.08); }
  @media (max-width: 860px) {
    .hero { min-height: auto; }
    .hero-bg {
      background-image:
        linear-gradient(90deg, rgba(7, 8, 45, 0.94), rgba(7, 8, 45, 0.78)),
        url('/assets/nati/hero-bg-flow-03.webp');
      background-position: 62% center;
    }
    .hero-grid { grid-template-columns: 1fr; }
    .hero-panel { max-width: 520px; }
    .actions { display: grid; }
  }
</style>
