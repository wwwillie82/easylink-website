---
import type { SitePage } from '@/lib/content/static';
import VideoMedia from '@/components/VideoMedia.astro';

type Props = { page?: SitePage; hero?: Partial<Pick<SitePage, 'heroEyebrow' | 'heroTitle' | 'heroDescription' | 'heroAsset' | 'heroVideo' | 'heroHeight' | 'heroImageFit' | 'heroImagePositionX' | 'heroImagePositionY' | 'heroImagePositionMobileX' | 'heroImagePositionMobileY' | 'heroOverlayStrength' | 'heroImageScale'>>; heroMeta?: { subtitle?: string; benefits?: Array<{ title: string; text?: string }> } };
const { page, hero, heroMeta = {} } = Astro.props;
const heroData = { ...page, ...hero };
import { getPublicSiteSettings } from '@/lib/content/settings';
const heroCta = (await getPublicSiteSettings()).defaultCta;


const heightPadding = { compact: 'clamp(28px, 3.4vw, 44px) 0 clamp(18px, 2.4vw, 28px)', normal: 'clamp(38px, 4.6vw, 62px) 0 clamp(22px, 2.8vw, 34px)', tall: 'clamp(72px, 8vw, 120px) 0 clamp(28px, 3.2vw, 42px)', xlarge: 'clamp(96px, 11vw, 160px) 0 clamp(34px, 4vw, 54px)' };
const bgSize = { cover: 'cover', contain: 'contain', stretch: '100% 100%' };
const overlays = {
  weak: ['rgba(7, 8, 45, 0.94) 0%, rgba(8, 10, 52, 0.82) 37%, rgba(8, 10, 52, 0.26) 62%, rgba(8, 10, 52, 0.08) 100%', 'rgba(7, 8, 45, 0.72), rgba(7, 8, 45, 0.02) 42%, rgba(7, 8, 45, 0.42)'],
  normal: ['rgba(7, 8, 45, 0.98) 0%, rgba(8, 10, 52, 0.92) 37%, rgba(8, 10, 52, 0.38) 62%, rgba(8, 10, 52, 0.14) 100%', 'rgba(7, 8, 45, 0.88), rgba(7, 8, 45, 0.03) 42%, rgba(7, 8, 45, 0.58)'],
  strong: ['rgba(7, 8, 45, 1) 0%, rgba(8, 10, 52, 0.96) 37%, rgba(8, 10, 52, 0.52) 62%, rgba(8, 10, 52, 0.24) 100%', 'rgba(7, 8, 45, 0.94), rgba(7, 8, 45, 0.08) 42%, rgba(7, 8, 45, 0.72)'],
};
const allowedHeight = Object.hasOwn(heightPadding, heroData?.heroHeight) ? heroData.heroHeight : 'normal';
const allowedFit = Object.hasOwn(bgSize, heroData?.heroImageFit) ? heroData.heroImageFit : 'cover';
const allowedOverlay = Object.hasOwn(overlays, heroData?.heroOverlayStrength) ? heroData.heroOverlayStrength : 'normal';
const clampPercent = (value, fallback) => Number.isInteger(Number(value)) ? Math.min(100, Math.max(0, Number(value))) : fallback;
const clampScale = (value) => Number.isInteger(Number(value)) ? Math.min(200, Math.max(50, Number(value))) : 100;
const scaledBgSize = (fit, scale) => {
  if (fit === 'stretch') return '100% 100%';
  if (scale === 100) return bgSize[fit];
  return `${scale}% auto`;
};
const x = clampPercent(heroData?.heroImagePositionX, 60);
const y = clampPercent(heroData?.heroImagePositionY, 50);
const mx = clampPercent(heroData?.heroImagePositionMobileX, 62);
const my = clampPercent(heroData?.heroImagePositionMobileY, y);
const scale = clampScale(heroData?.heroImageScale);
const [overlayPrimary, overlaySecondary] = overlays[allowedOverlay];
const videoPosterFit = allowedFit === 'stretch' ? 'fill' : allowedFit;
const styleVars = [
  `--home-hero-asset: url('${heroData?.heroAsset}')`,
  `--home-hero-padding: ${heightPadding[allowedHeight]}`,
  `--home-hero-bg-size: ${scaledBgSize(allowedFit, scale)}`,
  `--home-hero-bg-position: ${x}% ${y}%`,
  `--home-hero-bg-position-mobile: ${mx}% ${my}%`,
  `--home-hero-overlay-primary: ${overlayPrimary}`,
  `--home-hero-overlay-secondary: ${overlaySecondary}`,
  `--home-hero-image-scale: ${scale}`,
].join('; ');
const videoLayerVars = [
  `--video-poster-fit: ${videoPosterFit}`,
  `--video-poster-position: ${x}% ${y}%`,
].join('; ');

const benefits = Array.isArray(heroMeta.benefits) ? heroMeta.benefits : [];
const subtitle = heroMeta.subtitle || '';
const video = heroData?.heroVideo || null;
---

<section id="top" class:list={["hero", { "has-hero-video": !!video }]} style={styleVars}>
  {video && <div class="hero-video-layer" style={videoLayerVars}><VideoMedia config={video} mode="background" title={`${heroData?.heroTitle} háttérvideó`} fallback={heroData?.heroAsset} /></div>}
  <div class="hero-bg" aria-hidden="true"></div>
  {video && <div class="hero-video-overlay" aria-hidden="true"></div>}
  <div class="container hero-grid">
    <div class="hero-copy">
      <span class="eyebrow">{heroData?.heroEyebrow}</span>
      <h1>{heroData?.heroTitle}</h1>
      {subtitle && <p class="hero-subtitle">{subtitle}</p>}
      <p class="hero-description">
        {heroData?.heroDescription}
      </p>
      <div class="actions">
        <a class="button button-primary" href={heroCta.primaryUrl} data-easylink-cta="demo" data-easylink-cta-id="home-hero-demo" data-easylink-cta-slot="hero">{heroCta.primaryLabel}</a>
        {heroCta.secondaryLabel && heroCta.secondaryUrl && <a class="button button-secondary" href={heroCta.secondaryUrl} data-easylink-cta="trial" data-easylink-cta-id="home-hero-trial" data-easylink-cta-slot="hero">{heroCta.secondaryLabel}</a>}
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true"></div>
  </div>
  {benefits.length > 0 && <div class="container benefit-row" aria-label="Easylink előnyök">
    {benefits.map((benefit) => (
      <article>
        <h2>{benefit.title}</h2>
        <p>{benefit.text}</p>
      </article>
    ))}
  </div>}
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    min-height: var(--home-hero-min-height);
    color: white;
    background: var(--color-navy-deep);
    padding: var(--home-hero-padding);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(90deg, var(--home-hero-overlay-primary)),
      linear-gradient(0deg, var(--home-hero-overlay-secondary)),
      var(--home-hero-asset);
    background-size: cover, cover, var(--home-hero-bg-size);
    background-position: center, center, var(--home-hero-bg-position);
    background-repeat: no-repeat, no-repeat, no-repeat;
    transform: scale(1.01);
    z-index: 0;
  }

  .has-hero-video .hero-bg {
    background-image: var(--home-hero-asset);
    background-size: var(--home-hero-bg-size);
    background-position: var(--home-hero-bg-position);
    background-repeat: no-repeat;
    opacity: 1;
  }
  .hero-video-layer {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
  }
  .hero-video-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background-image:
      linear-gradient(90deg, var(--home-hero-overlay-primary)),
      linear-gradient(0deg, var(--home-hero-overlay-secondary));
    pointer-events: none;
  }
  .hero::after {
    content: "";
    position: absolute;
    inset: auto -14% -24% 28%;
    height: 250px;
    background: radial-gradient(ellipse at center, rgba(174, 255, 0, 0.2), transparent 62%);
    filter: blur(18px);
  }

  .hero-grid {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: minmax(520px, 0.98fr) minmax(320px, 1.02fr);
    gap: clamp(24px, 5vw, 68px);
    align-items: center;
  }

  .hero-copy { max-width: 680px; }
  .hero .eyebrow { margin-bottom: var(--space-xs); }
  .hero h1 { max-width: none; margin-bottom: 8px; font-size: var(--text-home-hero-title); white-space: nowrap; }

  .hero-subtitle {
    margin: 0 0 16px;
    color: var(--color-neon);
    font-size: var(--text-home-hero-subtitle);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.045em;
    text-wrap: balance;
  }

  .hero-description {
    max-width: 650px;
    color: rgba(255, 255, 255, 0.82);
    font-size: var(--text-body-lg);
  }

  .actions { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 22px; }

  .hero-visual {
    min-height: clamp(280px, 32vw, 420px);
    position: relative;
    pointer-events: none;
    background:
      radial-gradient(circle at 66% 32%, rgba(174, 255, 0, 0.16), transparent 24%),
      radial-gradient(circle at 46% 70%, rgba(24, 214, 255, 0.1), transparent 30%);
  }

  .benefit-row {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: clamp(16px, 2.4vw, 26px);
  }

  .benefit-row article {
    padding: 16px 18px;
    border-radius: 20px;
    border: 1px solid rgba(174, 255, 0, 0.24);
    background: rgba(255, 255, 255, 0.075);
    backdrop-filter: blur(10px);
  }

  .benefit-row h2 { margin-bottom: 5px; color: white; font-size: 1rem; letter-spacing: -0.02em; }
  .benefit-row p { margin: 0; color: rgba(255, 255, 255, 0.72); font-size: 0.9rem; line-height: 1.45; }

  @media (max-width: 920px) {
    .hero-bg {
      background-image:
        linear-gradient(90deg, rgba(7, 8, 45, 0.96), rgba(7, 8, 45, 0.76)),
        var(--home-hero-asset);
      background-size: cover, var(--home-hero-bg-size);
      background-position: center, var(--home-hero-bg-position-mobile);
    }
    .has-hero-video .hero-bg { background-position: var(--home-hero-bg-position-mobile); }
    .hero-video-layer { --video-poster-position: var(--home-hero-bg-position-mobile); }

    .hero-grid { grid-template-columns: 1fr; }
    .hero h1 { white-space: normal; }
    .hero-visual { min-height: 220px; }
    .benefit-row { grid-template-columns: 1fr; }
    .actions { display: grid; }
  }
</style>
