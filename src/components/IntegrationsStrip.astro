---
const integrations = [
  'NAV Online Számla',
  'Magyar bankok / PSD2 / Aggreg8',
  'Hostware',
  'Számlázz.hu',
  'Billingo',
  'Cégjelző',
];
---

<section id="integrációk" class="integrations">
  <div class="container flow">
    <div>
      <span class="eyebrow">Integrációs adatáramlás</span>
      <h2>Kapcsolódási irányok csomópontokként.</h2>
    </div>
    <div class="nodes">
      {integrations.map((item) => <span>{item}</span>)}
    </div>
  </div>
</section>

<style>
  .integrations {
    position: relative;
    overflow: hidden;
    padding: clamp(70px, 9vw, 118px) 0;
    background: #080a34;
    color: white;
  }
  .integrations::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(90deg, rgba(8, 10, 52, 0.92), rgba(8, 10, 52, 0.55)),
      url('/assets/nati/hero-bg-flow-02.webp');
    background-size: cover;
    background-position: center;
    opacity: 0.92;
  }
  .flow { position: relative; display: grid; grid-template-columns: 0.8fr 1.2fr; gap: 38px; align-items: center; }
  .flow h2 { font-size: clamp(2rem, 4vw, 3.4rem); }
  .nodes { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  .nodes span {
    min-height: 96px;
    border: 1px solid rgba(174, 255, 0, 0.3);
    border-radius: 22px;
    padding: 18px;
    display: grid;
    place-items: center;
    text-align: center;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(8px);
    font-weight: 800;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
  }
  @media (max-width: 900px) { .flow { grid-template-columns: 1fr; } .nodes { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .nodes { grid-template-columns: 1fr; } }
</style>
