---
const integrations = [
  'NAV Online Számla',
  'Magyar bankok / PSD2 / Aggreg8',
  'Hostware',
  'Számlázz.hu',
  'Billingo',
  'Cégjelző',
];
---

<section id="integrációk" class="integrations">
  <div class="container flow">
    <div>
      <span class="eyebrow">Integrációs adatáramlás</span>
      <h2>Kapcsolódási irányok csomópontokként.</h2>
      <p>A blokk nem kész runtime integrációkat állít, hanem a későbbi adatkapcsolatok üzleti térképét mutatja.</p>
    </div>
    <div class="nodes">
      {integrations.map((item) => <span>{item}</span>)}
    </div>
  </div>
</section>

<style>
  .integrations { position: relative; overflow: hidden; padding: clamp(58px, 7vw, 92px) 0; background: #080a34; color: white; }
  .integrations::before { content: ""; position: absolute; inset: 0; background-image: linear-gradient(90deg, rgba(8, 10, 52, 0.9), rgba(8, 10, 52, 0.5) 54%, rgba(8, 10, 52, 0.22)), url('/assets/nati/hero-bg-flow-02.webp'); background-size: cover; background-position: center right; opacity: 0.98; }
  .flow { position: relative; display: grid; grid-template-columns: 0.82fr 1.18fr; gap: 36px; align-items: center; }
  .flow h2 { font-size: clamp(1.8rem, 3.2vw, 3rem); }
  .flow p { color: rgba(255, 255, 255, 0.72); }
  .nodes { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; position: relative; }
  .nodes span { min-height: 82px; border: 1px solid rgba(174, 255, 0, 0.28); border-radius: 20px; padding: 16px; display: grid; place-items: center; text-align: center; background: rgba(255, 255, 255, 0.075); backdrop-filter: blur(8px); font-weight: 800; box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.055); }
  @media (max-width: 900px) { .flow { grid-template-columns: 1fr; } .nodes { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .nodes { grid-template-columns: 1fr; } }
</style>
