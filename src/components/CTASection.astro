---
const {
  primaryAnalyticsIntent = 'demo',
  secondaryAnalyticsIntent = 'trial',
  primaryAnalyticsId = 'cta-section-primary',
  secondaryAnalyticsId = 'cta-section-secondary',
  analyticsSlot = 'cta-section',
  block,
} = Astro.props;
const validIntent = (value) => ['demo','trial','email'].includes(String(value || '')) ? String(value) : '';
const safeId = (value, fallback) => String(value || fallback).trim().replace(/[^a-zA-Z0-9_.:-]/g, '-').slice(0, 80);
const cta = block?.items?.[0] ?? null;
const resolvedEyebrow = cta?.eyebrow || '';
const resolvedTitle = block?.title || '';
const resolvedDescription = block?.body || '';
const resolvedPrimaryLabel = cta?.label || '';
const resolvedPrimaryHref = cta?.url || '';
const resolvedSecondaryLabel = cta?.secondaryLabel || '';
const resolvedSecondaryHref = cta?.secondaryUrl || '';
const primaryIntent = validIntent(cta?.primaryAnalyticsIntent ?? cta?.analyticsIntent ?? primaryAnalyticsIntent);
const secondaryIntent = validIntent(cta?.secondaryAnalyticsIntent ?? secondaryAnalyticsIntent);
const slot = safeId(cta?.analyticsSlot ?? analyticsSlot, 'cta-section');
const shouldRender = Boolean(block && cta && resolvedTitle && resolvedPrimaryLabel && resolvedPrimaryHref);
---

{shouldRender && (


<section class="section cta">
  <div class="container box">
    <span class="eyebrow">{resolvedEyebrow}</span>
    <h2>{resolvedTitle}</h2>
    <p>{resolvedDescription}</p>
    <div class="actions">
      <a class="button button-primary" href={resolvedPrimaryHref} data-easylink-cta={primaryIntent || undefined} data-easylink-cta-id={primaryIntent ? safeId(cta.primaryAnalyticsId ?? cta.analyticsId ?? primaryAnalyticsId, 'cta-section-primary') : undefined} data-easylink-cta-slot={primaryIntent ? slot : undefined}>{resolvedPrimaryLabel}</a>
      {resolvedSecondaryLabel && resolvedSecondaryHref && <a class="button button-secondary" href={resolvedSecondaryHref} data-easylink-cta={secondaryIntent || undefined} data-easylink-cta-id={secondaryIntent ? safeId(cta.secondaryAnalyticsId ?? secondaryAnalyticsId, 'cta-section-secondary') : undefined} data-easylink-cta-slot={secondaryIntent ? slot : undefined}>{resolvedSecondaryLabel}</a>}
    </div>
  </div>
</section>


)}
<style>
  .cta { background: #f4f7f3; }
  .box { position: relative; overflow: hidden; text-align: center; border-radius: 28px; padding: clamp(34px, 5vw, 62px); background: linear-gradient(90deg, rgba(15, 17, 89, 0.96), rgba(15, 17, 89, 0.82)), url('/assets/nati/hero-bg-flow-01.webp'); background-size: cover; background-position: center; color: white; box-shadow: 0 34px 100px rgba(15, 17, 89, 0.22); }
  .box p { color: rgba(255, 255, 255, 0.72); max-width: 620px; margin: 0 auto 20px; }
  .box h2 { max-width: 760px; margin-inline: auto; }
  .actions { display: flex; justify-content: center; gap: 14px; flex-wrap: wrap; }
</style>
