---
import { getPublicSiteSettings } from '@/lib/content/settings';
import { resolvePageCta, resolvedCtaToBlock } from '@/lib/content/pageCta';
import { itemCtaButtons } from '@/lib/content/cta-buttons.mjs';

const {
  primaryAnalyticsIntent = 'demo',
  secondaryAnalyticsIntent = 'trial',
  primaryAnalyticsId = 'cta-section-primary',
  secondaryAnalyticsId = 'cta-section-secondary',
  analyticsSlot = 'cta-section',
  block: rawBlock,
} = Astro.props;
const validIntent = (value) => ['demo','trial','email'].includes(String(value || '')) ? String(value) : '';
const safeId = (value, fallback) => String(value || fallback).trim().replace(/[^a-zA-Z0-9_.:-]/g, '-').slice(0, 80);
const publicSettings = await getPublicSiteSettings();
const block = rawBlock?.resolvedPageCta ? rawBlock : resolvedCtaToBlock(resolvePageCta(rawBlock, publicSettings.defaultCta));
const cta = block?.items?.[0] ?? null;
const resolvedEyebrow = cta?.eyebrow || '';
const resolvedTitle = block?.title || '';
const resolvedDescription = block?.body || '';
const buttons = cta ? itemCtaButtons(cta) : [];
const shouldRender = Boolean(block && cta && resolvedTitle && buttons.length);
---

{shouldRender && (
  <section class="section cta">
    <div class="container box">
      <span class="eyebrow">{resolvedEyebrow}</span>
      <h2>{resolvedTitle}</h2>
      <p>{resolvedDescription}</p>
      <div class="actions">
        {buttons.map((button, index) => {
          const intent = validIntent(button.analyticsIntent ?? (index === 0 ? (cta?.primaryAnalyticsIntent ?? cta?.analyticsIntent ?? primaryAnalyticsIntent) : index === 1 ? (cta?.secondaryAnalyticsIntent ?? secondaryAnalyticsIntent) : ''));
          const id = safeId(button.analyticsId ?? (index === 0 ? (cta?.primaryAnalyticsId ?? cta?.analyticsId ?? primaryAnalyticsId) : index === 1 ? (cta?.secondaryAnalyticsId ?? secondaryAnalyticsId) : ''), `cta-section-${index + 1}`);
          const slot = safeId(button.analyticsSlot ?? cta?.analyticsSlot ?? analyticsSlot, 'cta-section');
          return (
            <a
              class={`button ${index === 0 ? 'button-primary' : 'button-secondary'}`}
              href={button.url}
              data-easylink-cta={intent || undefined}
              data-easylink-cta-id={intent ? id : undefined}
              data-easylink-cta-slot={intent ? slot : undefined}
            >
              {button.label}
            </a>
          );
        })}
      </div>
    </div>
  </section>
)}
<style>
  .cta { background: #f4f7f3; }
  .box { position: relative; overflow: hidden; text-align: center; border-radius: 28px; padding: clamp(34px, 5vw, 62px); background: linear-gradient(90deg, rgba(15, 17, 89, 0.96), rgba(15, 17, 89, 0.82)), url('/assets/nati/hero-bg-flow-01.webp'); background-size: cover; background-position: center; color: white; box-shadow: 0 34px 100px rgba(15, 17, 89, 0.22); }
  .box p { color: rgba(255, 255, 255, 0.72); max-width: 620px; margin: 0 auto 20px; }
  .box h2 { max-width: 760px; margin-inline: auto; }
  .actions { display: flex; justify-content: center; gap: 14px; flex-wrap: wrap; }
</style>
