---
import { deployUrl } from '@/content/siteNavigation';

const {
  title,
  description = 'Kérj demót vagy próbáld ki ingyen a konfigurált Deploy felületen.',
  eyebrow = 'Következő lépés',
  primaryLabel = 'Demót kérek',
  secondaryLabel = 'Próbáld ki ingyen',
  primaryHref = deployUrl,
  secondaryHref = deployUrl,
  block,
} = Astro.props;
const cta = block?.items?.[0] ?? {};
const resolvedEyebrow = cta.eyebrow ?? eyebrow;
const resolvedTitle = block?.title ?? title;
const resolvedDescription = block?.body ?? description;
const resolvedPrimaryLabel = cta.label ?? primaryLabel;
const resolvedPrimaryHref = cta.url || primaryHref;
const resolvedSecondaryLabel = cta.secondaryLabel ?? secondaryLabel;
const resolvedSecondaryHref = cta.secondaryUrl || secondaryHref;
---

<section class="section cta">
  <div class="container box">
    <span class="eyebrow">{resolvedEyebrow}</span>
    <h2>
      {
        resolvedTitle ?? (
          <>Készen állsz könnyedebben vezetni a céged?</>
        )
      }
    </h2>
    <p>{resolvedDescription}</p>
    <div class="actions">
      <a class="button button-primary" href={resolvedPrimaryHref}>{resolvedPrimaryLabel}</a>
      <a class="button button-secondary" href={resolvedSecondaryHref}>{resolvedSecondaryLabel}</a>
    </div>
  </div>
</section>

<style>
  .cta { background: #f4f7f3; }
  .box {
    position: relative;
    overflow: hidden;
    text-align: center;
    border-radius: 28px;
    padding: clamp(34px, 5vw, 62px);
    background:
      linear-gradient(90deg, rgba(15, 17, 89, 0.96), rgba(15, 17, 89, 0.82)),
      url('/assets/nati/hero-bg-flow-01.webp');
    background-size: cover;
    background-position: center;
    color: white;
    box-shadow: 0 34px 100px rgba(15, 17, 89, 0.22);
  }
  .box p { color: rgba(255, 255, 255, 0.72); max-width: 620px; margin: 0 auto 20px; }
  .box h2 { max-width: 760px; margin-inline: auto; }
  .actions { display: flex; justify-content: center; gap: 14px; flex-wrap: wrap; }
</style>
