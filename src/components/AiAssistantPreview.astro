<style>.ai{position:relative;overflow:hidden;background:#07082d;color:white}.ai:before{content:"";position:absolute;inset:0;background-image:linear-gradient(90deg,rgba(7,8,45,.9),rgba(7,8,45,.62)),url('/assets/nati/hero-bg-flow-01.webp');background-size:cover;background-position:center;opacity:.82}.ai-grid{position:relative;display:grid;grid-template-columns:.9fr 1.1fr;gap:42px;align-items:center}.ai-copy p{color:rgba(255,255,255,.75)}.chat{padding:28px;border-radius:32px;border:1px solid rgba(174,255,0,.25);background:rgba(255,255,255,.08);backdrop-filter:blur(14px);display:grid;gap:16px;box-shadow:0 30px 90px rgba(0,0,0,.25)}.source-row{display:flex;gap:10px;flex-wrap:wrap}.source-row span{background:rgba(174,255,0,.14);border:1px solid rgba(174,255,0,.3);color:var(--color-neon);font-weight:800;border-radius:999px;padding:8px 12px}.msg{padding:18px 20px;border-radius:22px;line-height:1.6}.user{background:rgba(15,17,89,.86);color:white;margin-left:8%;border:1px solid rgba(255,255,255,.14)}.bot{background:white;color:var(--color-navy);margin-right:8%}.bot p{color:var(--color-ink);margin:8px 0 0}@media(max-width:800px){.ai-grid{grid-template-columns:1fr}.user,.bot{margin-left:0;margin-right:0}}</style>
