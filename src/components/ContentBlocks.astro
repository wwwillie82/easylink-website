---
import { normalizePublicHref, publicHrefRel, publicHrefTarget } from '@/lib/content/links';
import ListingCards from '@/components/ListingCards.astro';
import VideoMedia from '@/components/VideoMedia.astro';
import AiPreviewBlock from '@/components/AiPreviewBlock.astro';
import NetworkVisualBlock from '@/components/NetworkVisualBlock.astro';
const { blocks = [] } = Astro.props;
const blockLabels = {
  text: 'Tartalom',
  'feature-list': 'Felsorolás',
  list: 'Felsorolás',
  cards: 'Kártyák',
  'card-grid': 'Kártyák',
  cta: 'Felhívás',
  'image-text': 'Kép és szöveg',
  faq: 'Gyakori kérdések',
  'ai-preview': 'AI és adatkapcsolat',
  'network-visual': 'Adatkapcsolat',
  video: 'Videó',
};
const asArray = (items) => Array.isArray(items) ? items : [];
const textOf = (item) => typeof item === 'string' ? item : (item?.title ?? item?.text ?? item?.label ?? '');
const linkAttrs = (value) => { const href = normalizePublicHref(value); return { href, target: publicHrefTarget(href), rel: publicHrefRel(href) }; };
const validIntent = (value) => ['demo','trial','email'].includes(String(value || '').trim()) ? String(value).trim() : '';
const safeId = (value) => String(value || '').trim().replace(/[^a-zA-Z0-9_.:-]/g, '-').slice(0, 80);
---
<section class="section light">
  <div class="container blocks">
    {blocks.map((block) => {
      const type = block.type === 'list' ? 'feature-list' : block.type;
      const items = asArray(block.items);
      const eyebrow = block.eyebrow ?? blockLabels[block.type] ?? block.type;
      if (type === 'text') {
        return <article class="content-card type-text"><span class="eyebrow">{eyebrow}</span><h2>{block.title}</h2>{block.body && <p>{block.body}</p>}</article>;
      }
      if (type === 'cta') {
        const cta = items[0] ?? {};
        const link = linkAttrs(cta.url);
        const intent = validIntent(cta.analyticsIntent);
        const analyticsId = safeId(cta.analyticsId);
        const slot = safeId(cta.analyticsSlot || block.blockKey || block.block_key || 'content-block');
        return <article class="content-card type-cta"><span class="eyebrow">{eyebrow}</span><h2>{block.title}</h2>{block.body && <p>{block.body}</p>}{link.href && <a class="button button-primary" href={link.href} target={link.target} rel={link.rel} data-easylink-cta={intent || undefined} data-easylink-cta-id={intent && analyticsId ? analyticsId : undefined} data-easylink-cta-slot={intent && analyticsId ? slot : undefined}>{cta.label || 'Tovább'}</a>}</article>;
      }
      if (type === 'cards' || type === 'card-grid') {
        return <article class="type-cards"><span class="eyebrow">{eyebrow}</span><h2>{block.title}</h2>{block.body && <p>{block.body}</p>}<ListingCards items={items} /></article>;
      }
      if (type === 'image-text') {
        const media = items[0] ?? {};
        return <article class:list={['content-card', 'type-image-text', media.position === 'left' ? 'image-left' : 'image-right']}><div>{media.image && <img src={media.image} alt={media.alt || ""} loading="lazy" />}</div><div><span class="eyebrow">{eyebrow}</span><h2>{block.title}</h2>{block.body && <p>{block.body}</p>}</div></article>;
      }
      if (type === 'ai-preview') {
        return <AiPreviewBlock block={block} />;
      }
      if (type === 'network-visual') {
        return <NetworkVisualBlock block={block} />;
      }
      if (type === 'video') {
        const video = items[0] ?? null;
        return <article class="content-card type-video"><span class="eyebrow">{eyebrow}</span><h2>{block.title}</h2>{block.body && <p>{block.body}</p>}<VideoMedia config={video} mode="inline" title={block.title || 'Videó'} /></article>;
      }
      if (type === 'faq') {
        return <article class="content-card type-faq"><span class="eyebrow">{eyebrow}</span><h2>{block.title}</h2>{block.body && <p>{block.body}</p>}{items.map((item) => <details><summary>{item.question || item.title}</summary><p>{item.answer || item.text}</p></details>)}</article>;
      }
      if (type === 'feature-list') {
        return <article class="content-card type-feature-list"><span class="eyebrow">{eyebrow}</span><h2>{block.title}</h2>{block.body && <p>{block.body}</p>}{items.length > 0 && <ul>{items.map((item) => { const href = typeof item === 'object' ? normalizePublicHref(item.url || item.href) : ''; const label = textOf(item); return <li>{href ? <a href={href} target={publicHrefTarget(href)} rel={publicHrefRel(href)}>{label}</a> : label}</li>; })}</ul>}</article>;
      }
      return <article class:list={['content-card', `type-${type}`]}><span class="eyebrow">{eyebrow}</span><h2>{block.title}</h2>{block.body && <p>{block.body}</p>}{items.length > 0 && <ul>{items.map((item) => <li>{textOf(item)}</li>)}</ul>}</article>;
    })}
  </div>
</section>
<style>
  .light { background: linear-gradient(180deg, #f6f8f5, #fff); }
  .blocks { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--card-gap); }
  .content-card { position: relative; overflow: hidden; border: 1px solid rgba(15, 17, 89, 0.1); border-radius: var(--radius-md); background: white; box-shadow: var(--shadow-card); padding: var(--card-padding); }
  .content-card::before { content: ""; position: absolute; inset: 0 0 auto; height: 4px; background: linear-gradient(90deg, var(--color-neon), var(--color-cyan)); }
  .content-card h2, .type-cards h2 { color: var(--color-navy); font-size: clamp(1.22rem, 1.45vw, 1.62rem); font-weight: 700; line-height: 1.22; letter-spacing: -0.025em; }
  .content-card p, .type-cards > p { color: var(--color-ink); line-height: 1.68; }
  .type-cards, .type-video { grid-column: 1 / -1; }
  .type-video { display: grid; gap: 16px; }
  .type-image-text { display: grid; grid-template-columns: .8fr 1.2fr; gap: 18px; align-items: center; }
  .type-image-text.image-right > div:first-child { order: 2; }
  .type-image-text img { width: 100%; border-radius: 18px; display: block; }
  .type-network-visual, .type-cta { background: linear-gradient(135deg, var(--color-navy), #080a34); color: white; }
  .type-network-visual h2, .type-cta h2 { color: white; }
  .type-network-visual p, .type-cta p { color: rgba(255, 255, 255, 0.75); }
  li { margin: 10px 0; color: var(--color-navy); font-weight: 600; line-height: 1.58; }
  .type-network-visual li { color: rgba(255, 255, 255, 0.92); }
  details { border-top: 1px solid rgba(15,17,89,.12); padding: 12px 0; }
  summary { cursor: pointer; font-weight: 800; color: var(--color-navy); }
  @media (max-width: 900px) { .blocks, .type-image-text { grid-template-columns: 1fr; } .type-image-text.image-right > div:first-child { order: 0; } }
</style>
