---
const { blocks = [], media } = Astro.props;
const blockLabels = { text: 'Mire jó?', 'feature-list': 'Vezetői haszon', 'ai-preview': 'AI és adatkapcsolat', 'network-visual': 'Adatkapcsolat' };
---
<section class="section light"><div class="container block-grid"><div class="blocks">{blocks.map((block) => (<article class:list={['content-card', `type-${block.type}`]}><span class="eyebrow">{blockLabels[block.type] ?? block.type}</span><h2>{block.title}</h2>{block.body && <p>{block.body}</p>}{block.items && (<ul>{block.items.map((item) => <li>{item}</li>)}</ul>)}</article>))}</div>{media && (<aside class="media-note"><b>Vizuális előkészítés</b><code>{media.path}</code><p>{media.todo}</p></aside>)}</div></section>
<style>.light{background:linear-gradient(180deg,#f6f8f5,#fff)}.block-grid{display:grid;grid-template-columns:minmax(0,1fr) 300px;gap:24px}.blocks{display:grid;gap:22px}.content-card,.media-note{position:relative;overflow:hidden;border:1px solid rgba(15,17,89,.1);border-radius:28px;background:white;box-shadow:0 22px 70px rgba(15,17,89,.09);padding:30px}.content-card:before{content:"";position:absolute;inset:0 auto 0 0;width:6px;background:linear-gradient(var(--color-neon),#19d7ff)}.content-card h2{color:var(--color-navy);font-size:clamp(1.65rem,3vw,2.6rem)}.type-ai-preview,.type-network-visual{background:linear-gradient(135deg,var(--color-navy),#080a34);color:white}.type-ai-preview p,.type-network-visual p{color:rgba(255,255,255,.75)}li{margin:12px 0;color:var(--color-navy);font-weight:700;line-height:1.55}.type-ai-preview li,.type-network-visual li{color:white}.media-note{align-self:start;background:#f8faf7;color:var(--color-muted);font-size:.88rem}.media-note b{display:block;color:var(--color-navy);margin-bottom:10px}code{display:block;white-space:normal;margin:12px 0;color:var(--color-navy)}@media(max-width:900px){.block-grid{grid-template-columns:1fr}}</style>
