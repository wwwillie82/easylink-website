---
const { items, basePath = '' } = Astro.props;
---
<div class="listing-grid">{items.map((item) => <a class="card listing-card" href={`${basePath}${item.slug}/`}><span>{String(item.order).padStart(2,'0')}</span><h3>{item.title}</h3><p>{item.shortDescription}</p></a>)}</div>
<style>.listing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}.listing-card{padding:28px;display:block}.listing-card span{width:48px;height:48px;border-radius:16px;background:var(--color-navy);color:var(--color-neon);display:grid;place-items:center;font-weight:800;margin-bottom:24px}.listing-card h3{color:var(--color-navy);font-size:1.25rem}@media(max-width:860px){.listing-grid{grid-template-columns:1fr}}</style>
