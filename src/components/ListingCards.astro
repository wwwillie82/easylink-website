---
import { normalizePublicHref, publicHrefRel, publicHrefTarget } from '@/lib/content/links';
const { items = [], basePath = '', defaultLinkLabel = 'Részletek →' } = Astro.props;

const normalizeHref = (item) => normalizePublicHref(item?.href ?? item?.url ?? item?.slug ?? '', { basePath });
const normalizeCard = (item, index) => {
  const href = normalizeHref(item);
  return {
    title: item?.title ?? '',
    text: item?.text ?? item?.shortDescription ?? item?.body ?? item?.detail ?? '',
    href,
    linkLabel: href ? (item?.linkLabel ?? item?.label ?? defaultLinkLabel) : '',
    badge: item?.badge ?? item?.order ?? index + 1,
  };
};
const cards = items.filter((item) => item?.status !== 'draft' && item?.status !== 'archived').map(normalizeCard);
---
<div class="listing-grid">
  {
    cards.map((item) => {
      const content = <><span class="number">{String(item.badge).padStart(2, '0')}</span><h3>{item.title}</h3>{item.text && <p>{item.text}</p>}{item.linkLabel && <i>{item.linkLabel}</i>}</>;
      return item.href ? (
        <a class="listing-card" href={item.href} target={publicHrefTarget(item.href)} rel={publicHrefRel(item.href)}>{content}</a>
      ) : (
        <article class="listing-card listing-card--static">{content}</article>
      );
    })
  }
</div>
<style>
  .listing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--card-gap); }
  .listing-card {
    position: relative;
    overflow: hidden;
    min-height: 188px;
    padding: var(--card-padding);
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(15, 17, 89, 0.1);
    border-radius: var(--radius-md);
    background: linear-gradient(180deg, #fff, #fbfcfa);
    box-shadow: var(--shadow-card);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .listing-card::before { content: ""; position: absolute; inset: 0 0 auto; height: 4px; background: linear-gradient(90deg, var(--color-neon), var(--color-cyan)); }
  .listing-card:hover, .listing-card:focus-visible { transform: translateY(-4px); border-color: rgba(174, 255, 0, 0.5); box-shadow: 0 28px 80px rgba(15, 17, 89, 0.16); outline: none; }
  .listing-card--static { cursor: default; }
  .listing-card--static:hover { transform: none; border-color: rgba(15, 17, 89, 0.1); box-shadow: var(--shadow-card); }
  .number { width: 38px; height: 38px; border-radius: 13px; display: grid; place-items: center; color: var(--color-neon); background: var(--color-navy); font-size: 0.88rem; font-weight: 800; }
  h3 { margin: 18px 0 8px; color: var(--color-navy); font-size: var(--text-card-title); line-height: 1.2; }
  p { margin-bottom: 18px; font-size: 0.98rem; }
  i { margin-top: auto; color: var(--color-navy); font-style: normal; font-weight: 800; }
  @media (max-width: 960px) { .listing-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 620px) { .listing-grid { grid-template-columns: 1fr; } }
</style>
