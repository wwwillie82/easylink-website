---
import type { PublicConsentSettings } from '@/lib/content/settings';
const { consent } = Astro.props as { consent: PublicConsentSettings };
const settingsJson = JSON.stringify(consent).replace(/</g, '\\u003c');
---
<div id="easylink-cookie-consent" data-consent-settings={settingsJson}></div>
<script is:inline>
(() => {
  const mount = document.getElementById('easylink-cookie-consent');
  if (!mount) return;
  const settings = JSON.parse(mount.dataset.consentSettings || '{}');
  const COOKIE_NAME = 'easylink_consent';
  const MAX_AGE_SECONDS = 60 * 60 * 24 * 180;
  const VERSION = Number(settings.configurationVersion || 0);
  const active = settings.active === true && Number.isInteger(VERSION) && VERSION > 0;
  const docs = { privacyPdfPath: String(settings.privacyPdfPath || ''), cookiePdfPath: String(settings.cookiePdfPath || '') };
  let lastOpener = null;
  let saved = readCookieState();
  let state = normalizeState(saved) || { version: VERSION || 1, necessary: 'granted', analytics: 'denied', updatedAt: new Date(0).toISOString() };
  let bannerShown = false;
  let dialogOpen = false;
  let analyticsInput = null;
  let modalRestore = [];

  function clone(s) { return { version: s.version, necessary: 'granted', analytics: s.analytics === 'granted' ? 'granted' : 'denied', updatedAt: s.updatedAt }; }
  function parseCookieValue(value) { try { if (!value || value.length > 512) return null; return JSON.parse(decodeURIComponent(value)); } catch { return null; } }
  function readRawCookie() { return document.cookie.split('; ').find((row) => row.startsWith(COOKIE_NAME + '='))?.slice(COOKIE_NAME.length + 1) || ''; }
  function normalizeState(raw) {
    if (!raw || typeof raw !== 'object') return null;
    const keys = Object.keys(raw).sort().join(',');
    if (keys !== 'analytics,necessary,updatedAt,version') return null;
    if (raw.version !== VERSION) return null;
    if (raw.necessary !== 'granted') return null;
    if (raw.analytics !== 'granted' && raw.analytics !== 'denied') return null;
    if (typeof raw.updatedAt !== 'string' || Number.isNaN(Date.parse(raw.updatedAt))) return null;
    return { version: VERSION, necessary: 'granted', analytics: raw.analytics, updatedAt: raw.updatedAt };
  }
  function readCookieState() { return active ? normalizeState(parseCookieValue(readRawCookie())) : null; }
  function cookieString(next) {
    const secure = location.protocol === 'https:' ? '; Secure' : '';
    return COOKIE_NAME + '=' + encodeURIComponent(JSON.stringify(next)) + '; Path=/; SameSite=Lax; Max-Age=' + MAX_AGE_SECONDS + secure;
  }
  function persist(analytics) {
    if (!active) return;
    state = { version: VERSION, necessary: 'granted', analytics: analytics === 'granted' ? 'granted' : 'denied', updatedAt: new Date().toISOString() };
    document.cookie = cookieString(state);
    const focusTarget = dialogOpen ? lastOpener : null;
    hideAll(focusTarget);
    window.dispatchEvent(new CustomEvent('easylink:consent-changed', { detail: clone(state) }));
  }
  function focusableElements(container) { return Array.from(container.querySelectorAll('button, [href], input:not([disabled]), select, textarea, [tabindex]:not([tabindex="-1"])')).filter((el) => !el.disabled); }
  function focusFirst(container) { (focusableElements(container)[0] || container).focus(); }
  function restoreModalIsolation() {
    for (const item of modalRestore) {
      if (item.inert === undefined) item.el.removeAttribute?.('inert'); else item.el.inert = item.inert;
      if (item.ariaHidden === null) item.el.removeAttribute?.('aria-hidden'); else item.el.setAttribute?.('aria-hidden', item.ariaHidden);
    }
    modalRestore = [];
  }
  function applyModalIsolation() {
    restoreModalIsolation();
    const children = Array.from(document.body?.children || []);
    for (const el of children) {
      if (el === mount) continue;
      modalRestore.push({ el, inert: 'inert' in el ? el.inert : undefined, ariaHidden: el.getAttribute?.('aria-hidden') ?? null });
      el.inert = true;
      el.setAttribute?.('aria-hidden', 'true');
    }
  }
  function fallbackFocusTarget(opener) {
    if (opener?.isConnected) return opener;
    const footerButton = document.querySelector?.('[data-easylink-open-cookie-settings]');
    if (footerButton?.isConnected) return footerButton;
    return document.body || null;
  }
  function focusAfterRemovedDom(opener) {
    const target = fallbackFocusTarget(opener);
    if (target?.focus) target.focus();
  }
  function hideAll(focusTarget = null) { restoreModalIsolation(); mount.innerHTML = ''; bannerShown = false; dialogOpen = false; if (focusTarget) focusAfterRemovedDom(focusTarget); }
  function showBanner() {
    if (!active) return hideAll();
    restoreModalIsolation();
    bannerShown = true; dialogOpen = false;
    mount.innerHTML = `<section class="el-consent-banner" aria-labelledby="el-consent-title"><h2 id="el-consent-title">Süti-beállítások</h2><p>Az oldal működéséhez szükséges sütiket mindig használjuk. Engedélyeddel látogatottsági statisztikát készítünk, hogy fejleszthessük az Easylink weboldalát.</p><div class="el-consent-actions"><button type="button" class="primary" data-accept>Statisztika engedélyezése</button><button type="button" data-reject>Csak szükséges sütik</button><button type="button" data-settings>Beállítások</button></div></section>`;
    mount.querySelector('[data-accept]').addEventListener('click', () => persist('granted'));
    mount.querySelector('[data-reject]').addEventListener('click', () => persist('denied'));
    mount.querySelector('[data-settings]').addEventListener('click', (e) => openSettings(e.currentTarget));
  }
  function openSettings(opener) {
    if (!active) return;
    lastOpener = opener || document.activeElement;
    const current = readCookieState();
    const checked = current?.analytics === 'granted' ? 'checked' : '';
    applyModalIsolation();
    dialogOpen = true; bannerShown = false;
    mount.innerHTML = `<div class="el-consent-backdrop"><section class="el-consent-dialog" role="dialog" aria-modal="true" aria-labelledby="el-consent-dialog-title"><h2 id="el-consent-dialog-title">Süti-beállítások</h2><div class="el-consent-category"><div><h3>Szükséges</h3><p>Az oldal alapvető működéséhez szükséges sütik, mindig bekapcsolva.</p></div><span aria-label="Szükséges sütik állapota: mindig bekapcsolva">Mindig bekapcsolva</span><input type="checkbox" checked disabled aria-label="Szükséges sütik mindig bekapcsolva"></div><label class="el-consent-category"><div><h3>Statisztikai</h3><p>Segít megérteni a weboldal használatát, hogy fejleszthessük a szolgáltatást.</p></div><input data-analytics-toggle type="checkbox" ${checked} aria-label="Statisztikai sütik engedélyezése"></label><nav class="el-consent-legal" aria-label="Jogi dokumentumok" hidden></nav><div class="el-consent-actions"><button type="button" class="primary" data-save>Kiválasztás mentése</button><button type="button" data-accept>Minden elfogadása</button><button type="button" data-reject>Csak szükséges sütik</button></div><button type="button" class="el-consent-close" aria-label="Beállítások bezárása mentés nélkül" data-close>Vissza</button></section></div>`;
    renderLegalLinks(mount.querySelector('.el-consent-legal'));
    analyticsInput = mount.querySelector('[data-analytics-toggle]');
    mount.querySelector('[data-save]').addEventListener('click', () => persist(analyticsInput.checked ? 'granted' : 'denied'));
    mount.querySelector('[data-accept]').addEventListener('click', () => persist('granted'));
    mount.querySelector('[data-reject]').addEventListener('click', () => persist('denied'));
    mount.querySelector('[data-close]').addEventListener('click', closeSettingsWithoutSave);
    focusFirst(mount.querySelector('[role="dialog"]'));
  }
  function safeLegalHref(value) {
    const href = String(value || '').trim();
    if (!href || !href.startsWith('/') || href.startsWith('//') || href.includes('://') || href.toLowerCase().startsWith('javascript:')) return '';
    if (/[\u0000-\u001f\u007f"'<>\\]/.test(href)) return '';
    const parts = href.split('/').filter(Boolean);
    if (parts.some((part) => part === '.' || part === '..')) return '';
    return href;
  }
  function renderLegalLinks(nav) {
    if (!nav) return;
    const links = [['privacyPdfPath', 'Adatkezelési Tájékoztató'], ['cookiePdfPath', 'Cookie Tájékoztató']];
    for (const [key, label] of links) {
      const href = safeLegalHref(docs[key]);
      if (!href) continue;
      const a = document.createElement('a');
      a.setAttribute('href', href);
      a.setAttribute('target', '_blank');
      a.setAttribute('rel', 'noopener noreferrer');
      a.textContent = label;
      nav.appendChild(a);
    }
    if (nav.children.length > 0) nav.hidden = false;
  }
  function focusBannerSettings() { const btn = mount.querySelector('[data-settings]'); if (btn?.focus) btn.focus(); }
  function closeSettingsWithoutSave() { const had = Boolean(readCookieState()); if (had) hideAll(lastOpener); else { showBanner(); focusBannerSettings(); } }
  document.addEventListener('keydown', (e) => {
    if (!dialogOpen) return;
    if (e.key === 'Escape') { e.preventDefault(); closeSettingsWithoutSave(); return; }
    if (e.key !== 'Tab') return;
    const dialog = mount.querySelector('[role="dialog"]');
    const items = dialog ? focusableElements(dialog) : [];
    if (items.length === 0) { e.preventDefault(); return; }
    const first = items[0];
    const last = items[items.length - 1];
    if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
    else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
  });
  window.EasylinkConsent = { getState: () => clone(state), openSettings: () => openSettings(null), acceptAnalytics: () => persist('granted'), rejectAnalytics: () => persist('denied') };
  document.addEventListener('click', (e) => { const btn = e.target.closest?.('[data-easylink-open-cookie-settings]'); if (btn) { e.preventDefault(); openSettings(btn); } });
  if (active && !saved) showBanner();
})();
</script>
<style>
  #easylink-cookie-consent { position: relative; z-index: 50; }
  .el-consent-banner, .el-consent-dialog { position: fixed; background: #fff; color: var(--color-navy); border: 1px solid var(--color-line); box-shadow: 0 18px 60px rgba(15, 36, 61, .18); border-radius: 18px; padding: 18px; }
  .el-consent-banner { right: 18px; bottom: 18px; max-width: 430px; }
  .el-consent-banner h2, .el-consent-dialog h2 { margin: 0 0 10px; font-size: 1.25rem; }
  .el-consent-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 14px; }
  .el-consent-actions button, .el-consent-close { border: 1px solid var(--color-navy); border-radius: 999px; padding: 10px 14px; background: #fff; color: var(--color-navy); font-weight: 800; cursor: pointer; }
  .el-consent-actions .primary { background: var(--color-navy); color: #fff; }
  .el-consent-actions button:focus-visible, .el-consent-close:focus-visible, .el-consent-legal a:focus-visible { outline: 3px solid #ffbf47; outline-offset: 3px; }
  .el-consent-backdrop { position: fixed; inset: 0; pointer-events: auto; background: rgba(15, 36, 61, .03); }
  .el-consent-dialog { pointer-events: auto; right: 18px; bottom: 18px; width: min(560px, calc(100vw - 36px)); max-height: calc(100vh - 36px); overflow: auto; }
  .el-consent-category { display: flex; justify-content: space-between; gap: 16px; align-items: center; border: 1px solid var(--color-line); border-radius: 14px; padding: 12px; margin: 10px 0; }
  .el-consent-category h3, .el-consent-category p { margin: 0; }
  .el-consent-category p { margin-top: 6px; }
  .el-consent-category input { width: 24px; height: 24px; flex: 0 0 auto; }
  .el-consent-legal { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 12px; }
  .el-consent-close { margin-top: 12px; }
  @media (max-width: 700px) { .el-consent-banner, .el-consent-dialog { left: 12px; right: 12px; bottom: 12px; width: auto; max-width: none; max-height: calc(100vh - 24px); } }
  @media (prefers-reduced-motion: reduce) { .el-consent-banner, .el-consent-dialog { scroll-behavior: auto; } }
</style>
