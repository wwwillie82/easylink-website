---
const {
  eyebrow = 'easylink',
  title,
  description,
  dark = true,
  variant = 'listing',
  asset = '/assets/nati/hero-bg-flow-02.webp',
} = Astro.props;
---
<section class:list={['page-hero', `page-hero-${variant}`, { light: !dark }]} style={`--page-hero-asset: url('${asset}')`}>
  <div class="container page-hero-grid">
    <div class="page-hero-copy">
      <span class="eyebrow">{eyebrow}</span>
      <h1>{title}</h1>
      <p>{description}</p>
    </div>
    <div class="page-hero-visual" aria-hidden="true"></div>
  </div>
</section>
<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    background: var(--color-navy-deep);
    color: white;
    padding: var(--page-hero-padding) 0;
  }

  .page-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(90deg, rgba(8, 10, 52, 0.98) 0%, rgba(8, 10, 52, 0.88) 43%, rgba(8, 10, 52, 0.26) 72%, rgba(8, 10, 52, 0.08) 100%),
      var(--page-hero-asset);
    background-size: cover;
    background-position: 66% center;
    opacity: 0.98;
  }

  .page-hero-detail { padding: var(--detail-hero-padding) 0; }
  .page-hero-detail::before { opacity: 0.78; }

  .page-hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(200px, 0.45fr);
    gap: clamp(18px, 3vw, 34px);
    align-items: center;
  }

  .page-hero-copy { max-width: var(--container-narrow); }
  .page-hero .eyebrow { margin-bottom: var(--space-xs); }
  .page-hero h1 { max-width: 15ch; margin-bottom: var(--space-sm); font-size: var(--text-page-hero-title); line-height: 1.04; text-wrap: balance; }
  .page-hero-detail h1 { max-width: 17ch; font-size: var(--text-detail-hero-title); }
  .page-hero p { max-width: 720px; color: rgba(255, 255, 255, 0.8); font-size: var(--text-body-lg); }

  .page-hero-visual {
    min-height: clamp(120px, 14vw, 180px);
    position: relative;
    pointer-events: none;
    background: radial-gradient(circle at 58% 42%, rgba(174, 255, 0, 0.14), transparent 34%);
  }

  .page-hero-detail .page-hero-visual { min-height: 104px; opacity: 0.68; }

  @media (max-width: 860px) {
    .page-hero { padding: 36px 0 40px; }
    .page-hero::before {
      background-image:
        linear-gradient(90deg, rgba(8, 10, 52, 0.96), rgba(8, 10, 52, 0.78)),
        var(--page-hero-asset);
      background-position: 58% center;
    }
    .page-hero-grid { grid-template-columns: 1fr; }
    .page-hero-visual { min-height: 100px; }
  }
</style>
