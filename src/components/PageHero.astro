---
import VideoMedia from '@/components/VideoMedia.astro';
const {
  eyebrow = 'easylink',
  title,
  description,
  dark = true,
  variant = 'listing',
  asset = '/assets/nati/hero-bg-flow-02.webp',
  height = 'normal',
  imageFit = 'cover',
  imagePositionX = 66,
  imagePositionY = 50,
  imagePositionMobileX,
  imagePositionMobileY,
  overlayStrength = 'normal',
  imageScale = 100,
  video = null,
} = Astro.props;
const normalPadding = variant === 'detail' ? 'clamp(28px, 3.6vw, 46px)' : 'clamp(36px, 4.4vw, 58px)';
const normalPaddingMobile = variant === 'detail' ? 'clamp(24px, 4vw, 40px)' : 'clamp(36px, 4.4vw, 58px)';
const heightPadding = { compact: 'clamp(24px, 3vw, 34px)', normal: normalPadding, tall: 'clamp(64px, 7vw, 94px)', xlarge: 'clamp(84px, 9vw, 124px)' };
const heightPaddingMobile = { compact: 'clamp(22px, 5vw, 32px)', normal: normalPaddingMobile, tall: 'clamp(44px, 8vw, 62px)', xlarge: 'clamp(56px, 10vw, 78px)' };
const listingHeightMin = { compact: '310px', normal: '380px', tall: '450px', xlarge: '520px' };
const listingHeightMinMobile = { compact: '250px', normal: '300px', tall: '350px', xlarge: '400px' };
const detailHeightMin = { compact: '260px', normal: '320px', tall: '380px', xlarge: '440px' };
const detailHeightMinMobile = { compact: '220px', normal: '260px', tall: '300px', xlarge: '340px' };
const heightMin = variant === 'detail' ? detailHeightMin : listingHeightMin;
const heightMinMobile = variant === 'detail' ? detailHeightMinMobile : listingHeightMinMobile;
const bgSize = { cover: 'cover', contain: 'contain', stretch: '100% 100%' };
const overlays = {
  weak: ['rgba(8, 10, 52, 0.9)', 'rgba(8, 10, 52, 0.72)', 'rgba(8, 10, 52, 0.18)', 'rgba(8, 10, 52, 0.04)', '0.92'],
  normal: ['rgba(8, 10, 52, 0.98)', 'rgba(8, 10, 52, 0.88)', 'rgba(8, 10, 52, 0.26)', 'rgba(8, 10, 52, 0.08)', '0.98'],
  strong: ['rgba(8, 10, 52, 1)', 'rgba(8, 10, 52, 0.94)', 'rgba(8, 10, 52, 0.42)', 'rgba(8, 10, 52, 0.18)', '1'],
};
const allowedHeight = Object.hasOwn(heightPadding, height) ? height : 'normal';
const allowedFit = Object.hasOwn(bgSize, imageFit) ? imageFit : 'cover';
const allowedOverlay = Object.hasOwn(overlays, overlayStrength) ? overlayStrength : 'normal';
const clampPercent = (value, fallback) => Number.isInteger(Number(value)) ? Math.min(100, Math.max(0, Number(value))) : fallback;
const clampScale = (value) => Number.isInteger(Number(value)) ? Math.min(200, Math.max(50, Number(value))) : 100;
const scaledBgSize = (fit, scale) => {
  if (fit === 'stretch') return '100% 100%';
  if (scale === 100) return bgSize[fit];
  return fit === 'cover' ? `${scale}% auto` : `${scale}% auto`;
};
const x = clampPercent(imagePositionX, 66);
const y = clampPercent(imagePositionY, 50);
const mx = clampPercent(imagePositionMobileX, x);
const my = clampPercent(imagePositionMobileY, y);
const scale = clampScale(imageScale);
const [overlayLeft, overlayMid, overlayRight, overlayEnd, overlayOpacity] = overlays[allowedOverlay];
const detailOverlayOpacity = String(Math.round(Number(overlayOpacity) * 0.8 * 1000) / 1000);
const styleVars = [
  `--page-hero-asset: url('${asset}')`,
  `--page-hero-padding: ${heightPadding[allowedHeight]}`,
  `--page-hero-padding-mobile: ${heightPaddingMobile[allowedHeight]}`,
  `--page-hero-min-height: ${heightMin[allowedHeight]}`,
  `--page-hero-min-height-mobile: ${heightMinMobile[allowedHeight]}`,
  `--page-hero-bg-size: ${scaledBgSize(allowedFit, scale)}`,
  `--page-hero-image-scale: ${scale}`,
  `--page-hero-bg-position: ${x}% ${y}%`,
  `--page-hero-bg-position-mobile: ${mx}% ${my}%`,
  `--page-hero-overlay-left: ${overlayLeft}`,
  `--page-hero-overlay-mid: ${overlayMid}`,
  `--page-hero-overlay-right: ${overlayRight}`,
  `--page-hero-overlay-end: ${overlayEnd}`,
  `--page-hero-overlay-opacity: ${overlayOpacity}`,
  `--video-poster-fit: ${allowedFit === 'stretch' ? 'fill' : allowedFit}`,
  `--video-poster-position: ${x}% ${y}%`,
  `--page-hero-detail-overlay-opacity: ${detailOverlayOpacity}`,
].join('; ');
---
<section class:list={['page-hero', `page-hero-${variant}`, { light: !dark, 'has-hero-video': !!video }]} style={styleVars}>
  {video && <VideoMedia config={video} mode="background" title={`${title || 'Hero'} háttérvideó`} fallback={asset} />}
  {video && <div class="page-hero-overlay" aria-hidden="true"></div>}
  <div class="container page-hero-grid">
    <div class="page-hero-copy">
      <span class="eyebrow">{eyebrow}</span>
      <h1>{title}</h1>
      <p>{description}</p>
    </div>
    <div class="page-hero-visual" aria-hidden="true"></div>
  </div>
</section>
<style>
  .page-hero { position: relative; overflow: hidden; min-height: var(--page-hero-min-height); background: var(--color-navy-deep); color: white; padding: var(--page-hero-padding) 0; display: flex; align-items: center; }
  .page-hero::before { content: ""; position: absolute; inset: 0; background-image: linear-gradient(90deg, var(--page-hero-overlay-left) 0%, var(--page-hero-overlay-mid) 43%, var(--page-hero-overlay-right) 72%, var(--page-hero-overlay-end) 100%), var(--page-hero-asset); background-size: cover, var(--page-hero-bg-size); background-position: center, var(--page-hero-bg-position); background-repeat: no-repeat, no-repeat; opacity: var(--page-hero-overlay-opacity); }
  .page-hero-overlay { position: absolute; inset: 0; z-index: 0; background: linear-gradient(90deg, var(--page-hero-overlay-left) 0%, var(--page-hero-overlay-mid) 43%, var(--page-hero-overlay-right) 72%, var(--page-hero-overlay-end) 100%); opacity: var(--page-hero-overlay-opacity); pointer-events: none; }
  .page-hero-detail:not(.has-hero-video)::before { opacity: var(--page-hero-detail-overlay-opacity); }
  .page-hero-detail.has-hero-video .page-hero-overlay { opacity: var(--page-hero-detail-overlay-opacity); }
  .has-hero-video::before { background-image: var(--page-hero-asset); background-position: var(--page-hero-bg-position); background-repeat: no-repeat; opacity: 1; }
  .has-hero-video .video-media { z-index: 0; }
  .page-hero-grid { position: relative; z-index: 1; display: grid; grid-template-columns: minmax(0, 1fr) minmax(200px, 0.45fr); gap: clamp(18px, 3vw, 34px); align-items: center; }
  .page-hero-copy { max-width: var(--container-narrow); }
  .page-hero .eyebrow { margin-bottom: var(--space-xs); }
  .page-hero h1 { max-width: 15ch; margin-bottom: var(--space-sm); font-size: var(--text-page-hero-title); line-height: 1.04; text-wrap: balance; }
  .page-hero-detail h1 { max-width: 17ch; font-size: var(--text-detail-hero-title); }
  .page-hero p { max-width: 720px; color: rgba(255, 255, 255, 0.8); font-size: var(--text-body-lg); }
  .page-hero-visual { min-height: clamp(120px, 14vw, 180px); position: relative; pointer-events: none; background: radial-gradient(circle at 58% 42%, rgba(174, 255, 0, 0.14), transparent 34%); }
  .page-hero-detail .page-hero-visual { min-height: 104px; opacity: 0.68; }
  @media (max-width: 860px) { .page-hero { --video-poster-position: var(--page-hero-bg-position-mobile); min-height: var(--page-hero-min-height-mobile); padding: var(--page-hero-padding-mobile) 0; } .page-hero::before { background-image: linear-gradient(90deg, var(--page-hero-overlay-left), var(--page-hero-overlay-mid)), var(--page-hero-asset); background-position: center, var(--page-hero-bg-position-mobile); } .has-hero-video::before { background-image: var(--page-hero-asset); background-position: var(--page-hero-bg-position-mobile); } .page-hero-overlay { background: linear-gradient(90deg, var(--page-hero-overlay-left), var(--page-hero-overlay-mid)); } .page-hero-grid { grid-template-columns: 1fr; } .page-hero-visual { min-height: 100px; } }
</style>
