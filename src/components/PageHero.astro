---
const {
  eyebrow = 'easylink',
  title,
  description,
  dark = true,
  variant = 'listing',
  asset = '/assets/nati/hero-bg-flow-02.webp',
} = Astro.props;
---
<section class:list={['page-hero', `page-hero-${variant}`, { light: !dark }]} style={`--page-hero-asset: url('${asset}')`}>
  <div class="container page-hero-grid">
    <div class="page-hero-copy">
      <span class="eyebrow">{eyebrow}</span>
      <h1>{title}</h1>
      <p>{description}</p>
    </div>
    <div class="page-hero-visual" aria-hidden="true">
      <span>{variant === 'detail' ? 'Fókuszált üzleti nézet' : 'Adatkapcsolati keret'}</span>
    </div>
  </div>
</section>
<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    background: var(--color-navy-deep);
    color: white;
    padding: var(--page-hero-padding) 0;
  }

  .page-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(90deg, rgba(8, 10, 52, 0.96), rgba(8, 10, 52, 0.83) 44%, rgba(8, 10, 52, 0.34) 74%, rgba(8, 10, 52, 0.18)),
      var(--page-hero-asset);
    background-size: cover;
    background-position: 62% center;
    opacity: 0.98;
  }

  .page-hero-detail { padding: var(--detail-hero-padding) 0; }
  .page-hero-detail::before { opacity: 0.78; }

  .page-hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.98fr) minmax(220px, 0.52fr);
    gap: clamp(18px, 3vw, 34px);
    align-items: center;
  }

  .page-hero-copy { max-width: var(--container-narrow); }
  .page-hero h1 { max-width: 15ch; margin-bottom: var(--space-sm); font-size: var(--text-page-hero-title); line-height: 1.04; text-wrap: balance; }
  .page-hero-detail h1 { max-width: 17ch; font-size: var(--text-detail-hero-title); }
  .page-hero p { max-width: 720px; color: rgba(255, 255, 255, 0.8); font-size: var(--text-body-lg); }

  .page-hero-visual {
    min-height: clamp(130px, 15vw, 190px);
    border-radius: 24px;
    border: 1px solid rgba(174, 255, 0, 0.18);
    background: linear-gradient(135deg, rgba(174, 255, 0, 0.12), rgba(255, 255, 255, 0.035));
    backdrop-filter: blur(5px);
    position: relative;
  }

  .page-hero-detail .page-hero-visual { min-height: 112px; opacity: 0.72; }

  .page-hero-visual span {
    position: absolute;
    left: 18px;
    bottom: 16px;
    color: rgba(255, 255, 255, 0.74);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 860px) {
    .page-hero { padding: 36px 0 40px; }
    .page-hero::before {
      background-image:
        linear-gradient(90deg, rgba(8, 10, 52, 0.96), rgba(8, 10, 52, 0.78)),
        var(--page-hero-asset);
      background-position: 58% center;
    }
    .page-hero-grid { grid-template-columns: 1fr; }
    .page-hero-visual { min-height: 100px; }
  }
</style>
