---
const { eyebrow = 'easylink', title, description, dark = true } = Astro.props;
---
<section class:list={['page-hero', { light: !dark }]}><div class="container page-hero-grid"><div><span class="eyebrow">{eyebrow}</span><h1>{title}</h1><p>{description}</p></div><div class="data-visual" aria-hidden="true"><span>Flow</span><i></i><i></i><i></i><i></i></div></div></section>
<style>.page-hero{position:relative;overflow:hidden;background:#080a34;color:white;padding:clamp(76px,9vw,128px) 0}.page-hero:before{content:"";position:absolute;inset:0;background-image:linear-gradient(90deg,rgba(8,10,52,.95),rgba(8,10,52,.7),rgba(8,10,52,.35)),url('/assets/nati/hero-bg-flow-02.webp');background-size:cover;background-position:center right}.page-hero.light{background:var(--color-soft);color:var(--color-navy)}.page-hero.light:before{opacity:.18}.page-hero p{max-width:760px;color:rgba(255,255,255,.78);font-size:1.08rem}.light p{color:var(--color-muted)}.page-hero-grid{position:relative;display:grid;grid-template-columns:1.1fr .9fr;gap:44px;align-items:center}.data-visual{min-height:300px;border:1px solid rgba(174,255,0,.25);border-radius:30px;background:rgba(255,255,255,.07);position:relative;overflow:hidden;backdrop-filter:blur(8px)}.data-visual span{position:absolute;left:24px;top:22px;color:var(--color-neon);font-weight:800}.data-visual:before{content:"";position:absolute;inset:22%;border:1px solid rgba(174,255,0,.36);border-radius:50%;filter:drop-shadow(0 0 18px rgba(174,255,0,.5))}.data-visual i{position:absolute;width:15px;height:15px;border-radius:50%;background:var(--color-neon);box-shadow:var(--shadow-neon)}.data-visual i:nth-child(2){left:18%;top:24%}.data-visual i:nth-child(3){left:68%;top:30%}.data-visual i:nth-child(4){left:38%;top:72%}.data-visual i:nth-child(5){left:78%;top:70%;background:white}@media(max-width:860px){.page-hero-grid{grid-template-columns:1fr}.data-visual{min-height:220px}}</style>
