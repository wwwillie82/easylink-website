---
const {
  eyebrow = 'easylink',
  title,
  description,
  dark = true,
  variant = 'listing',
} = Astro.props;
---
<section class:list={['page-hero', `page-hero-${variant}`, { light: !dark }]}>
  <div class="container page-hero-grid">
    <div class="page-hero-copy">
      <span class="eyebrow">{eyebrow}</span>
      <h1>{title}</h1>
      <p>{description}</p>
    </div>
    <div class="page-hero-visual" aria-hidden="true">
      <span class="visual-label">Adatkapcsolat</span>
      <div class="visual-orbit"></div>
      <i></i>
      <i></i>
      <i></i>
    </div>
  </div>
</section>
<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    background: var(--color-navy-deep);
    color: white;
    padding: var(--page-hero-padding) 0;
  }

  .page-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(90deg, rgba(8, 10, 52, 0.96), rgba(8, 10, 52, 0.82) 48%, rgba(8, 10, 52, 0.42)),
      url('/assets/nati/hero-bg-flow-02.webp');
    background-size: cover;
    background-position: center right;
    opacity: 0.92;
  }

  .page-hero::after {
    content: "";
    position: absolute;
    inset: auto -12% -46% 48%;
    height: 210px;
    background: radial-gradient(ellipse at center, rgba(174, 255, 0, 0.18), transparent 64%);
    filter: blur(20px);
  }

  .page-hero.light {
    background: var(--color-soft);
    color: var(--color-navy);
  }

  .page-hero.light::before { opacity: 0.18; }

  .page-hero-detail { padding: var(--detail-hero-padding) 0; }

  .page-hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(190px, 0.32fr);
    gap: clamp(20px, 3.5vw, 40px);
    align-items: center;
  }

  .page-hero-copy {
    max-width: var(--container-narrow);
  }

  .page-hero h1 {
    max-width: 12.5ch;
    margin-bottom: var(--space-sm);
    font-size: var(--text-page-hero-title);
    line-height: 1.04;
    text-wrap: balance;
  }

  .page-hero-detail h1 {
    max-width: 14ch;
    font-size: var(--text-detail-hero-title);
  }

  .page-hero p {
    max-width: var(--container-reading);
    color: rgba(255, 255, 255, 0.8);
    font-size: var(--text-body-lg);
  }

  .page-hero.light p { color: var(--color-muted); }

  .page-hero-visual {
    min-height: clamp(150px, 17vw, 210px);
    border: 1px solid rgba(174, 255, 0, 0.2);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(circle at 72% 28%, rgba(174, 255, 0, 0.18), transparent 24%),
      rgba(255, 255, 255, 0.06);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(8px);
    box-shadow: 0 28px 90px rgba(0, 0, 0, 0.18);
  }

  .visual-label {
    position: absolute;
    left: 18px;
    top: 16px;
    color: var(--color-neon);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .visual-orbit {
    position: absolute;
    inset: 28% 22% 18%;
    border: 1px solid rgba(174, 255, 0, 0.32);
    border-radius: 50%;
    filter: drop-shadow(0 0 18px rgba(174, 255, 0, 0.32));
  }

  .page-hero-visual i {
    position: absolute;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-neon);
    box-shadow: var(--shadow-neon);
  }

  .page-hero-visual i:nth-of-type(1) { left: 24%; top: 34%; }
  .page-hero-visual i:nth-of-type(2) { left: 70%; top: 38%; background: white; }
  .page-hero-visual i:nth-of-type(3) { left: 48%; top: 72%; background: var(--color-cyan); }

  @media (max-width: 860px) {
    .page-hero {
      padding: 40px 0 44px;
    }

    .page-hero::before {
      background-image:
        linear-gradient(90deg, rgba(8, 10, 52, 0.95), rgba(8, 10, 52, 0.8)),
        url('/assets/nati/hero-bg-flow-02.webp');
      background-position: 58% center;
    }

    .page-hero-grid { grid-template-columns: 1fr; }
    .page-hero h1 { max-width: 13.5ch; }
    .page-hero-visual { min-height: 140px; }
  }
</style>
