---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import PageHero from '@/components/PageHero.astro';
import CTASection from '@/components/CTASection.astro';
import Footer from '@/components/Footer.astro';
---

<BaseLayout title="Áraink | Easylink" description="Easylink árak és csomagok előkészített public oldal.">
  <Header />
  <main>
    <PageHero
      eyebrow="Áraink"
      title="Árazás, ami a működésedhez igazodik."
      description="Konkrét csomagárakat még nem publikálunk, és ezen az oldalon nem készül kalkulátor. A cél egy érthető public előkészítő oldal demó CTA-val."
    />
    <section class="section light">
      <div class="container price-grid">
        <article class="card">
          <h2>Mitől függhet az ár?</h2>
          <ul>
            <li>Választott moduloktól: pénzügy, CRM, dokumentumkezelés, kontrolling vagy AI irány.</li>
            <li>Cégmérettől, felhasználói köröktől és adminisztrációs összetettségtől.</li>
            <li>Előkészített vagy később bizonyított integrációktól.</li>
            <li>Bevezetési, adat-előkészítési és támogatási igényektől.</li>
          </ul>
        </article>
        <article class="card placeholder">
          <span class="eyebrow">Későbbi hely</span>
          <h2>Csomagárak és árkalkulátor</h2>
          <p>
            Itt kaphatnak helyet a későbbi csomagok és egy árajánlat-kalkulátor,
            de most nem implementálunk belépéshez kötött funkciót vagy kalkulátor logikát.
          </p>
        </article>
      </div>
    </section>
    <CTASection title="Kérj demót, és beszéljük át a modulokat." description="A pontos ajánlat a választott funkcióktól, cégmérettől és integrációs igényektől függ." />
  </main>
  <Footer />
</BaseLayout>

<style>
  .light { background: var(--color-soft); }
  .price-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
  .card { padding: 28px; }
  h2 { color: var(--color-navy); font-size: clamp(1.8rem, 4vw, 3rem); }
  li { margin: 12px 0; color: var(--color-navy); line-height: 1.55; font-weight: 600; }
  .placeholder { background: linear-gradient(180deg, #fff, #f0f5eb); }
  @media (max-width: 860px) { .price-grid { grid-template-columns: 1fr; } }
</style>
