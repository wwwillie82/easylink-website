---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import PageHero from '@/components/PageHero.astro';
import ListingCards from '@/components/ListingCards.astro';
import CTASection from '@/components/CTASection.astro';
import Footer from '@/components/Footer.astro';
import { publishedSolutions } from '@/content/solutions';
import { getPageByRoute } from '@/lib/content/provider';
const page = await getPageByRoute('/megoldasaink/');
---

<BaseLayout title={page?.seoTitle ?? "Megoldásaink | Easylink"} description={page?.seoDescription ?? "Easylink megoldások pénzügy, HR, CRM, dokumentumkezelés, kontrolling és AI területekre."}>
  <Header />
  <main>
    <PageHero
      eyebrow={page?.heroEyebrow ?? "megoldasaink"}
      title={page?.heroTitle ?? "Megoldásaink"}
      description={page?.heroDescription ?? "Valódi többoldalas struktúrában bemutatott, későbbi site admin szerkesztésre előkészített megoldások."}
    />
    <section class="section light">
      <div class="container">
        <ListingCards items={publishedSolutions} basePath="/megoldasaink/" />
      </div>
    </section>
    <CTASection />
  </main>
  <Footer />
</BaseLayout>

<style>
  .light { background: var(--color-soft); }
</style>
