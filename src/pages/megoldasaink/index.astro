---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import PageHero from '@/components/PageHero.astro';
import ListingCards from '@/components/ListingCards.astro';
import CTASection from '@/components/CTASection.astro';
import Footer from '@/components/Footer.astro';
import { publishedSolutions } from '@/content/solutions';
---

<BaseLayout title="Megoldásaink | Easylink" description="Easylink megoldások pénzügy, HR, CRM, dokumentumkezelés, kontrolling és AI területekre.">
  <Header />
  <main>
    <PageHero
      eyebrow="Megoldásaink"
      title="Egy rendszer a napi működés kulcspontjaira."
      description="Valódi többoldalas struktúrában bemutatott, későbbi site admin szerkesztésre előkészített megoldások."
    />
    <section class="section light">
      <div class="container">
        <ListingCards items={publishedSolutions} basePath="/megoldasaink/" />
      </div>
    </section>
    <CTASection />
  </main>
  <Footer />
</BaseLayout>

<style>
  .light { background: var(--color-soft); }
</style>
