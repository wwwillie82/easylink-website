---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import PageHero from '@/components/PageHero.astro';
import ListingCards from '@/components/ListingCards.astro';
import ContentBlocks from '@/components/ContentBlocks.astro';
import CTASection from '@/components/CTASection.astro';
import Footer from '@/components/Footer.astro';
import { publishedSolutions } from '@/content/solutions';
import { getPublicPageState } from '@/lib/content/provider';
import { findRoleBlock, withoutBlocks } from '@/lib/content/blockRoles';
const pageState = await getPublicPageState('/megoldasaink/');
const page = pageState.page;
const cardsBlock = findRoleBlock(page?.blocks, 'golden-cards', (block) => ['cards', 'card-grid'].includes(block.type));
const solutionCards = cardsBlock?.items?.length ? cardsBlock.items : publishedSolutions;
const ctaSectionBlock = findRoleBlock(page?.blocks, 'cta-section', (block) => block.type === 'cta');
const remainingBlocks = withoutBlocks(page?.blocks, [cardsBlock, ctaSectionBlock]);
if (pageState.hiddenByDb) Astro.response.status = 404;
---

<BaseLayout title={page?.seoTitle ?? "Megoldásaink | Easylink"} description={page?.seoDescription ?? "Easylink megoldások pénzügy, HR, CRM, dokumentumkezelés, kontrolling és AI területekre."}>
  <Header />
  <main>
    {pageState.hiddenByDb ? <section class="section"><div class="container"><h1>Az oldal nem található.</h1></div></section> : <>
    <PageHero
      eyebrow={page?.heroEyebrow ?? "megoldasaink"}
      title={page?.heroTitle ?? "Megoldásaink"}
      description={page?.heroDescription ?? "Válaszd ki, melyik működési területet szeretnéd átláthatóbbá tenni: pénzügy, HR, CRM, dokumentumkezelés, kontrolling vagy AI támogatás."}
      asset={page?.heroAsset || undefined}
      height={page?.heroHeight}
      imageFit={page?.heroImageFit}
      imagePositionX={page?.heroImagePositionX}
      imagePositionY={page?.heroImagePositionY}
      imagePositionMobileX={page?.heroImagePositionMobileX}
      imagePositionMobileY={page?.heroImagePositionMobileY}
      overlayStrength={page?.heroOverlayStrength}
      imageScale={page?.heroImageScale}
      video={page?.heroVideo}
    />
    <section class="section light">
      <div class="container">
        <ListingCards items={solutionCards} basePath="/megoldasaink/" />
      </div>
    </section>
    {remainingBlocks.length > 0 && <ContentBlocks blocks={remainingBlocks} />}
    <CTASection block={ctaSectionBlock} />
    </>}
  </main>
  <Footer />
</BaseLayout>

<style>
  .light { background: var(--color-soft); }
</style>
