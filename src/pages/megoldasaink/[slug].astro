---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import PageHero from '@/components/PageHero.astro';
import ContentBlocks from '@/components/ContentBlocks.astro';
import RelatedLinks from '@/components/RelatedLinks.astro';
import CTASection from '@/components/CTASection.astro';
import Footer from '@/components/Footer.astro';
import { publishedSolutions } from '@/content/solutions';
import { getDetailPage } from '@/lib/content/provider';

export function getStaticPaths() {
  return publishedSolutions.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const props = Astro.props;
const item = await getDetailPage('solution_detail', props.item.slug) ?? props.item;
const related = publishedSolutions
  .filter((entry) => entry.slug !== item.slug)
  .slice(0, 3)
  .map((entry) => ({ title: entry.title, href: `/megoldasaink/${entry.slug}/` }));
---

<BaseLayout title={item.seoTitle} description={item.seoDescription}>
  <Header />
  <main>
    <PageHero eyebrow="Megoldásaink" title={item.heroTitle} description={item.heroDescription} variant="detail" asset={item.heroAsset || undefined} height={item.heroHeight} imageFit={item.heroImageFit} imagePositionX={item.heroImagePositionX} imagePositionY={item.heroImagePositionY} imagePositionMobileX={item.heroImagePositionMobileX} imagePositionMobileY={item.heroImagePositionMobileY} overlayStrength={item.heroOverlayStrength} imageScale={item.heroImageScale} />
    <ContentBlocks blocks={item.blocks} />
    <RelatedLinks links={related} />
    <CTASection />
  </main>
  <Footer />
</BaseLayout>
