---
import BaseLayout from '@/layouts/BaseLayout.astro';import Header from '@/components/Header.astro';import PageHero from '@/components/PageHero.astro';import CTASection from '@/components/CTASection.astro';import Footer from '@/components/Footer.astro';import { publishedIntegrations } from '@/content/integrations';
---
<BaseLayout title="Integrációk | Easylink" description="NAV Online Számla, magyar bankok, Hostware, Számlázz.hu, Billingo és Cégjelző integrációs irányok."><Header/><main><PageHero eyebrow="Integrációk" title="Kapcsolódások, adatáramlás, tisztább működés." description="Az integrációs registry előkészíti a későbbi site admin által szerkeszthető partner- és adatkapcsolati tartalmakat."/><section class="section light"><div class="container integration-grid">{publishedIntegrations.map((item)=><article class="card"><span>{String(item.order).padStart(2,'0')}</span><h3>{item.title}</h3><p>{item.shortDescription}</p><code>{item.media.path}</code></article>)}</div></section><CTASection/></main><Footer/></BaseLayout>
<style>.light{background:var(--color-soft)}.integration-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}.card{padding:28px}.card span{color:var(--color-neon);font-weight:800}.card h3{color:var(--color-navy)}code{color:var(--color-muted);white-space:normal}@media(max-width:860px){.integration-grid{grid-template-columns:1fr}}</style>
