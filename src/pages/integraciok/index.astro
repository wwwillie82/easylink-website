---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import PageHero from '@/components/PageHero.astro';
import CTASection from '@/components/CTASection.astro';
import Footer from '@/components/Footer.astro';
import { publishedIntegrations } from '@/content/integrations';
---

<BaseLayout title="Integrációk | Easylink" description="NAV Online Számla, magyar bankok, Hostware, Számlázz.hu, Billingo és Cégjelző integrációs irányok.">
  <Header />
  <main>
    <PageHero
      eyebrow="Integrációk"
      title="Kapcsolódások, adatáramlás, tisztább működés."
      description="Az integrációs registry előkészíti a későbbi partner- és adatkapcsolati tartalmakat. Ahol nincs bizonyított éles kapcsolat, ott integrációs irányként kommunikálunk."
    />
    <section class="section light network-section">
      <div class="container intro"><span class="eyebrow">Csomópontok</span><h2>Nem késznek állított ígéretek, hanem tisztán tagolt integrációs irányok.</h2></div>
      <div class="container integration-grid">
        {publishedIntegrations.map((item) => (
          <article class="card integration-card">
            <span>{String(item.order).padStart(2, '0')}</span>
            <h3>{item.title}</h3>
            <p>{item.shortDescription}</p>
            <p class="detail">{item.detail}</p>
            <code>{item.media.path}</code>
          </article>
        ))}
      </div>
    </section>
    <CTASection />
  </main>
  <Footer />
</BaseLayout>

<style>
  .light { background: var(--color-soft); }
  .network-section { background: linear-gradient(180deg, #f6f8f5, #fff); }
  .intro { margin-bottom: 28px; }
  .intro h2 { max-width: 920px; color: var(--color-navy); font-size: clamp(2rem, 4vw, 3.3rem); }
  .integration-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .integration-card { position: relative; overflow: hidden; padding: 28px; border-radius: 28px; box-shadow: 0 22px 70px rgba(15,17,89,.1); }
  .integration-card:before { content: ""; position: absolute; inset: 0 0 auto; height: 5px; background: linear-gradient(90deg, var(--color-neon), #16d7ff); }
  .integration-card span { color: var(--color-neon); background: var(--color-navy); width: 46px; height: 46px; border-radius: 16px; display: grid; place-items: center; font-weight: 800; }
  .integration-card h3 { color: var(--color-navy); }
  .detail { color: var(--color-ink); font-weight: 400; }
  code { color: var(--color-muted); white-space: normal; }
  @media (max-width: 860px) { .integration-grid { grid-template-columns: 1fr; } }
</style>
