---
import BaseLayout from '@/layouts/BaseLayout.astro';import Header from '@/components/Header.astro';import PageHero from '@/components/PageHero.astro';import ListingCards from '@/components/ListingCards.astro';import CTASection from '@/components/CTASection.astro';import Footer from '@/components/Footer.astro';import { publishedAudiences } from '@/content/audiences';
---
<BaseLayout title="Kinek szól? | Easylink" description="Easylink hoteleknek, vendéglátóhelyeknek és szolgáltató vállalkozásoknak."><Header/><main><PageHero eyebrow="Kinek szól?" title="Iparági fókusz, admin-kompatibilis tartalommal." description="A public site külön route-okon mutatja be, mely vállalkozásoknak ad könnyebb cégvezetést az Easylink."/><section class="section light"><div class="container"><ListingCards items={publishedAudiences} basePath="/kinek-szol/"/></div></section><CTASection/></main><Footer/></BaseLayout>
<style>.light{background:var(--color-soft)}</style>
