---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import PageHero from '@/components/PageHero.astro';
import ContentBlocks from '@/components/ContentBlocks.astro';
import Footer from '@/components/Footer.astro';
import { getPublicPageState } from '@/lib/content/provider';
const pageState = await getPublicPageState('/kinek-szol/');
const page = pageState.page;
if (pageState.hiddenByDb) Astro.response.status = 404;
---
<BaseLayout title={page?.seoTitle} description={page?.seoDescription}>
  <Header />
  {pageState.hiddenByDb ? <main><section class="section"><div class="container"><h1>Az oldal nem található.</h1></div></section></main> : <main>
    <PageHero eyebrow={page?.heroEyebrow} title={page?.heroTitle} description={page?.heroDescription} asset={page?.heroAsset || undefined} />
    <ContentBlocks blocks={page?.blocks || []} />
  </main>}
  <Footer />
</BaseLayout>
