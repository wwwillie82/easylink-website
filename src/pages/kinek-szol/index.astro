---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import PageHero from '@/components/PageHero.astro';
import ListingCards from '@/components/ListingCards.astro';
import CTASection from '@/components/CTASection.astro';
import Footer from '@/components/Footer.astro';
import { publishedAudiences } from '@/content/audiences';
import { getPublicPageState } from '@/lib/content/provider';
const pageState = await getPublicPageState('/kinek-szol/');
const page = pageState.page;
if (pageState.hiddenByDb) Astro.response.status = 404;
---

<BaseLayout title={page?.seoTitle ?? "Kinek szól? | Easylink"} description={page?.seoDescription ?? "Easylink hoteleknek, vendéglátóhelyeknek és szolgáltató vállalkozásoknak."}>
  <Header />
  <main>
    {pageState.hiddenByDb ? <section class="section"><div class="container"><h1>Az oldal nem található.</h1></div></section> : <>
    <PageHero
      eyebrow={page?.heroEyebrow ?? "kinek-szol"}
      title={page?.heroTitle ?? "Kinek szól?"}
      description={page?.heroDescription ?? "A public site külön route-okon mutatja be, mely vállalkozásoknak ad könnyebb cégvezetést az Easylink."}
      asset={page?.heroAsset || undefined}
    />
    <section class="section light">
      <div class="container">
        <ListingCards items={publishedAudiences} basePath="/kinek-szol/" />
      </div>
    </section>
    <CTASection />
    </>}
  </main>
  <Footer />
</BaseLayout>

<style>
  .light { background: var(--color-soft); }
</style>
