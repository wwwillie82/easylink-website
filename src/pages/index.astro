---
import BaseLayout from '@/layouts/BaseLayout.astro';import Header from '@/components/Header.astro';import Hero from '@/components/Hero.astro';import ListingCards from '@/components/ListingCards.astro';import AiAssistantPreview from '@/components/AiAssistantPreview.astro';import IntegrationsStrip from '@/components/IntegrationsStrip.astro';import CTASection from '@/components/CTASection.astro';import Footer from '@/components/Footer.astro';
import { publishedSolutions } from '@/content/solutions';import { publishedAudiences } from '@/content/audiences';
---
<BaseLayout><Header/><main><Hero/><section class="section light"><div class="container"><span class="eyebrow">Megoldásaink</span><h2>Egy rendszer a napi működés kulcspontjaira.</h2><ListingCards items={publishedSolutions.slice(0,3)} basePath="/megoldasaink/"/><p class="more"><a class="button button-secondary" href="/megoldasaink/">Összes megoldás</a></p></div></section><AiAssistantPreview/><IntegrationsStrip/><section class="section"><div class="container"><span class="eyebrow">Kinek szól?</span><h2>Hoteleknek, vendéglátóhelyeknek és szolgáltató vállalkozásoknak.</h2><ListingCards items={publishedAudiences} basePath="/kinek-szol/"/></div></section><CTASection/></main><Footer/></BaseLayout>
<style>.more{margin-top:28px}.light{background:var(--color-soft)}h2{max-width:900px}</style>
