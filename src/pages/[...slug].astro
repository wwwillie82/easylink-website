---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { listPublishedPublicPages } from '@/lib/content/provider';
import { buildPublicRouteIndex, normalizePublicRoute, routeToStaticParam } from '@/lib/content/public-pages';
import { getPublicPageRenderer } from '@/components/page-renderers/registry';

export async function getStaticPaths() {
  const { mode, pages } = await listPublishedPublicPages();
  return pages.map((page) => {
    if (page.route === '/' || page.type === 'home') throw new Error(`Home oldal nem generálható catch-all route-ból: ${page.route}`);
    return { params: { slug: routeToStaticParam(page.route) }, props: { page, allPages: pages, mode } };
  });
}

const page = Astro.props.page;
const allPages = Astro.props.allPages ?? [];
const mode = Astro.props.mode;
const requestedRoute = normalizePublicRoute(`/${Astro.params.slug ?? ''}/`);
const routeIndex = buildPublicRouteIndex(allPages);
if (!page) throw new Error(`Published public oldal nem található a catch-all propsban: ${requestedRoute}`);
if (normalizePublicRoute(page.route) !== requestedRoute) throw new Error(`A catch-all props route és a kért route eltér: props=${page.route} requested=${requestedRoute}`);
if (page.route === '/' || page.type === 'home') throw new Error(`Home oldal nem renderelhető catch-all route-on: ${page.route}`);
const Renderer = getPublicPageRenderer(page.type);
---

<BaseLayout title={page.seoTitle} description={page.seoDescription}>
  <Header />
  <main>
    <Renderer page={page} routeIndex={routeIndex} mode={mode} />
  </main>
  <Footer />
</BaseLayout>
