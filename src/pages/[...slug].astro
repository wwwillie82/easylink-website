---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import PageHero from '@/components/PageHero.astro';
import ContentBlocks from '@/components/ContentBlocks.astro';
import CTASection from '@/components/CTASection.astro';
import Footer from '@/components/Footer.astro';
import { getPageByRoute, listContentPages } from '@/lib/content/provider';
import { findRoleBlock, withoutBlocks } from '@/lib/content/blockRoles';

export async function getStaticPaths() {
  const pages = await listContentPages();
  return pages.map((page) => ({ params: { slug: page.route.replace(/^\//, '').replace(/\/$/, '') }, props: { route: page.route } }));
}

const route = Astro.props.route || `/${Astro.params.slug}/`;
const page = await getPageByRoute(route);
if (!page || page.type !== 'content_page' || page.status !== 'published') return Astro.redirect('/404');
const ctaSectionBlock = findRoleBlock(page.blocks, 'cta-section', (block) => block.type === 'cta');
const contentBlocks = withoutBlocks(page.blocks, [ctaSectionBlock]);
---

<BaseLayout title={page.seoTitle} description={page.seoDescription}>
  <Header />
  <main>
    <PageHero eyebrow={page.heroEyebrow} title={page.heroTitle} description={page.heroDescription} asset={page.heroAsset || undefined} height={page.heroHeight} imageFit={page.heroImageFit} imagePositionX={page.heroImagePositionX} imagePositionY={page.heroImagePositionY} imagePositionMobileX={page.heroImagePositionMobileX} imagePositionMobileY={page.heroImagePositionMobileY} overlayStrength={page.heroOverlayStrength} imageScale={page.heroImageScale} />
    <ContentBlocks blocks={contentBlocks} />
    <CTASection block={ctaSectionBlock} />
  </main>
  <Footer />
</BaseLayout>
