{
  "name": "easylink-website",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "build": "astro build",
    "preview": "astro preview --host 0.0.0.0",
    "check": "astro sync && tsc --noEmit",
    "smoke:markup": "node scripts/smoke-markup.mjs",
    "admin:server": "node scripts/admin-server.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:seed": "node scripts/db-seed.mjs",
    "db:check": "node scripts/db-check.mjs",
    "admin:init": "node scripts/admin-init.mjs",
    "smoke:admin": "node tests/admin-smoke.mjs",
    "smoke:publish": "node tests/publish-smoke.mjs",
    "smoke:header": "node tests/header-navigation-smoke.mjs",
    "smoke:live": "node scripts/smoke-live-site.mjs",
    "smoke:composition": "node tests/public-composition-smoke.mjs",
    "smoke:media-storage": "node tests/media-storage-smoke.mjs",
    "smoke:content-adopt": "node tests/content-adopt-golden-smoke.mjs",
    "admin:media-worker": "node scripts/media-worker.mjs",
    "smoke:media-video": "node tests/media-video-smoke.mjs",
    "smoke:video-content": "node tests/video-content-smoke.mjs",
    "smoke:video-regressions": "node tests/video-regressions-smoke.mjs",
    "smoke:video-admin-runtime": "node tests/video-admin-runtime-smoke.mjs && node tests/video-draft-guard-smoke.mjs",
    "smoke:video-final": "node tests/video-final-smoke.mjs",
    "smoke:ai-preview": "node tests/ai-preview-smoke.mjs",
    "smoke:network-visual": "node tests/network-visual-smoke.mjs",
    "admin:publish": "node scripts/admin-publish.mjs",
    "smoke:settings": "node tests/settings-smoke.mjs",
    "smoke:legal-documents": "node tests/legal-documents-smoke.mjs",
    "smoke:cookie-consent": "node tests/cookie-consent-smoke.mjs && node tests/cookie-consent-style-smoke.mjs",
    "smoke:ga4-runtime": "node tests/ga4-runtime-smoke.mjs",
    "smoke:cta-tracking": "node tests/cta-tracking-smoke.mjs"
  },
  "dependencies": {
    "astro": "7.0.5",
    "typescript": "6.0.3",
    "mysql2": "3.11.5",
    "busboy": "1.6.0"
  },
  "devDependencies": {}
}
