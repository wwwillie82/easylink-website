# Public content source: static keeps builds DB-free; auto falls back when DB is unavailable; db is explicit runtime DB mode.
SITE_CONTENT_SOURCE=static

# MariaDB connection. Prefer one style; never commit real staging/production credentials.
# DATABASE_URL=mysql://user:password@127.0.0.1:3306/easylink_site
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=easylink_site
DB_USER=easylink_site
DB_PASSWORD=

# Site admin runtime/session. Use a long random value in staging/production.
SITE_ADMIN_SESSION_SECRET=
SITE_ADMIN_PORT=4322
SITE_ADMIN_BOOTSTRAP_EMAIL=admin@example.com
SITE_ADMIN_BOOTSTRAP_PASSWORD=
SITE_ADMIN_BASE_URL=https://site-dev.easylink.hu
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
